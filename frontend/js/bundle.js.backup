const HomePage = () => {
  const { user } = useAuth();
  const [recommendedUsers, setRecommendedUsers] = useState([]);
  const [stats, setStats] = useState({ offered: 0, wanted: 0, active: 0, completed: 0, rating: 'New' });
  const [recentActivity, setRecentActivity] = useState([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    const load = async () => {
      try {
        const [profile, incoming, outgoing, notifs, users] = await Promise.all([
          window.apiClient.getMe(),
          window.apiClient.getRequests({ type: 'received', limit: 20 }),
          window.apiClient.getRequests({ type: 'sent', limit: 20 }),
          window.apiClient.getNotifications(),
          window.apiClient.getUsers({ page: 1, limit: 8 }),
        ]);

        const allRequests = [...(incoming.requests || []), ...(outgoing.requests || [])];
        const activeCount = allRequests.filter((r) => ['pending', 'accepted'].includes(r.status)).length;
        const completedCount = allRequests.filter((r) => r.status === 'completed').length;
        setStats({
          offered: (profile.skills_offered || []).length,
          wanted: (profile.skills_wanted || []).length,
          active: activeCount,
          completed: completedCount,
          rating: profile.rating ? profile.rating.toFixed(1) : 'New',
        });

        const wanted = profile.skills_wanted || [];
        const recs = (users.users || []).filter((u) => (u.skills_offered || []).some((s) => wanted.includes(s))).slice(0, 4);
        setRecommendedUsers(recs);
        setRecentActivity((notifs.notifications || []).slice(0, 5));
      } catch (e) {
        console.error('Home page load failed:', e);
      } finally {
        setLoading(false);
      }
    };
    load();
  }, []);

  if (loading) return <Loading />;

  const statCards = [
    { label: 'Total Skills Offered', value: stats.offered, icon: '🎯' },
    { label: 'Total Skills Wanted', value: stats.wanted, icon: '📚' },
    { label: 'Active Requests', value: stats.active, icon: '⏳' },
    { label: 'Completed Swaps', value: stats.completed, icon: '✅' },
    { label: 'User Rating', value: stats.rating === 'New' ? 'No ratings yet' : `⭐ ${stats.rating}`, icon: '⭐' },
  ];

  return (
    <div className="min-h-screen bg-slate-950 text-slate-100">
      <div className="max-w-7xl mx-auto px-4 py-8 space-y-8">
        <div className="rounded-2xl bg-gradient-to-r from-brand-600 to-purple-600 text-white p-8 shadow-lg">
          <h1 className="text-3xl font-bold mb-2">Welcome back, {user?.first_name || 'there'}</h1>
          <p className="text-brand-100 mb-5">Find people to exchange skills and grow together.</p>
          <div className="flex flex-wrap gap-3">
            <a href="#discover" className="px-6 py-2.5 bg-white text-brand-600 font-medium rounded-xl hover:bg-brand-50 transition-all duration-300 hover:scale-105 hover:shadow-lg inline-flex items-center gap-2">
              🔍 Find People
            </a>
            <a href="#profile" className="px-6 py-2.5 bg-white/20 backdrop-blur-sm text-white font-medium rounded-xl hover:bg-white/30 transition-all duration-300 hover:scale-105 border border-white/30 inline-flex items-center gap-2">
              ✏️ Edit Profile
            </a>
          </div>
        </div>

        <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
          {statCards.map((item) => (
            <div key={item.label} className="bg-slate-800/60 border border-slate-700 rounded-xl p-4 shadow-sm hover:shadow-lg hover:border-brand-500/30 transition-all hover:-translate-y-1">
              <div className="text-2xl mb-2">{item.icon}</div>
              <div className="text-xl font-bold text-white">{item.value}</div>
              <div className="text-xs text-slate-400">{item.label}</div>
            </div>
          ))}
        </div>

        <section>
          <div className="flex items-center justify-between mb-4">
            <h2 className="text-xl font-bold">Recommended for You</h2>
            <a href="#discover" className="text-indigo-600 text-sm font-medium hover:text-indigo-700">See all</a>
          </div>
          {recommendedUsers.length === 0 ? (
            <div className="bg-slate-800/60 border border-slate-700 rounded-xl p-8 text-center">
              <div className="text-4xl mb-3">🎯</div>
              <p className="text-slate-400 mb-4">No recommendations yet</p>
              <a href="#profile" className="inline-flex items-center gap-2 px-5 py-2.5 bg-brand-600 text-white font-medium rounded-xl hover:bg-brand-500 transition-all duration-300 hover:scale-105">
                → Add skills to get recommendations
              </a>
            </div>
          ) : (
            <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
              {recommendedUsers.map((u) => (
                <div key={u.id} className="bg-slate-800/60 border border-slate-700 rounded-xl p-4 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5">
                  <div className="flex items-center gap-3 mb-3">
                    <div className="w-11 h-11 rounded-full bg-indigo-100 text-indigo-700 font-semibold flex items-center justify-center">{(u.first_name || 'U')[0].toUpperCase()}</div>
                    <div>
                      <h3 className="font-semibold text-white">{u.first_name || 'Unknown'}</h3>
                      <p className="text-xs text-slate-400">{u.location || 'Unknown'}</p>
                    </div>
                  </div>
                  <p className="text-xs text-slate-400 mb-2">Skills offered</p>
                  <div className="flex flex-wrap gap-1 mb-3">
                    {(u.skills_offered || []).slice(0, 3).map((s, i) => <span key={i} className="px-2 py-0.5 text-xs rounded-full bg-emerald-50 text-emerald-700 border border-emerald-200">{s}</span>)}
                  </div>
                  <p className="text-xs text-amber-600 mb-3">⭐ {u.rating ? u.rating.toFixed(1) : 'New'} rating</p>
                  <div className="grid grid-cols-2 gap-2">
                    <button onClick={() => window.location.hash = '#discover'} className="py-2 rounded-lg border border-slate-600 text-sm hover:bg-slate-700/40">View Profile</button>
                    <button onClick={() => window.location.hash = '#discover'} className="py-2 rounded-lg bg-indigo-600 text-white text-sm hover:bg-indigo-500">Send Swap</button>
                  </div>
                </div>
              ))}
            </div>
          )}
        </section>

        <section className="bg-slate-800/60 border border-slate-700 rounded-xl p-5 shadow-sm">
          <h2 className="text-xl font-bold mb-4">Recent Activity</h2>
          {recentActivity.length === 0 ? (
            <div className="text-center py-8">
              <div className="text-4xl mb-3">📊</div>
              <p className="text-slate-400">Your swaps and activity will appear here</p>
            </div>
          ) : (
            <div className="space-y-3">
              {recentActivity.map((a) => (
                <div key={a.id} className="flex gap-3">
                  <div className="w-2 h-2 mt-2 rounded-full bg-indigo-500"></div>
                  <div>
                    <p className="text-sm text-slate-300">{a.message}</p>
                    <p className="text-xs text-slate-400">{new Date(a.created_at).toLocaleString()}</p>
                  </div>
                </div>
              ))}
            </div>
          )}
        </section>
      </div>
    </div>
  );
};

const NotificationsPage = () => {
  const [items, setItems] = useState([]);
  const [loading, setLoading] = useState(true);

  const load = async () => {
    setLoading(true);
    try {
      const res = await window.apiClient.getNotifications();
      setItems(res.notifications || []);
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => { load(); }, []);

  const markRead = async (id) => {
    await window.apiClient.markNotificationRead(id);
    load();
  };

  const clearAll = async () => {
    await window.apiClient.markAllNotificationsRead();
    load();
  };

  if (loading) return <Loading />;

  return (
    <div className="min-h-screen bg-slate-950">
      <div className="max-w-4xl mx-auto px-4 py-8">
        <div className="flex items-center justify-between mb-5">
          <h1 className="text-2xl font-bold text-white">Notifications</h1>
          <button onClick={clearAll} className="px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm hover:bg-indigo-500">Clear all</button>
        </div>
        {items.length === 0 ? (
          <div className="bg-slate-800/60 border border-slate-700 rounded-xl p-8 text-center text-slate-400">No notifications available.</div>
        ) : (
          <div className="bg-slate-800/60 border border-slate-700 rounded-xl divide-y divide-slate-700/60">
            {items.map((n) => (
              <div key={n.id} className="p-4 flex items-start justify-between gap-4 hover:bg-slate-700/30 transition-colors">
                <div>
                  <p className={`text-sm ${n.is_read ? 'text-slate-300' : 'text-white font-medium'}`}>{n.message}</p>
                  <p className="text-xs text-slate-400 mt-1">{new Date(n.created_at).toLocaleString()}</p>
                </div>
                {!n.is_read && <button onClick={() => markRead(n.id)} className="text-xs text-indigo-600 hover:text-indigo-700">Mark as read</button>}
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  );
};

const MessagesPage = () => {
  const [requests, setRequests] = useState([]);
  const [loading, setLoading] = useState(true);
  const [selectedRequest, setSelectedRequest] = useState(null);
  const [messages, setMessages] = useState([]);
  const [messageText, setMessageText] = useState('');
  const [sendingMessage, setSendingMessage] = useState(false);
  const { user } = useAuth();

  useEffect(() => {
    const load = async () => {
      setLoading(true);
      try {
        const [sent, received] = await Promise.all([
          window.apiClient.getRequests({ type: 'sent', status: 'accepted', limit: 50 }),
          window.apiClient.getRequests({ type: 'received', status: 'accepted', limit: 50 }),
        ]);
        const map = {};
        [...(sent.requests || []), ...(received.requests || [])].forEach((r) => { map[r.id] = r; });
        const allRequests = Object.values(map);
        setRequests(allRequests);
        
        // Check for request ID in URL
        const hash = window.location.hash;
        const params = new URLSearchParams(hash.split('?')[1]);
        const requestId = params.get('request');
        
        if (requestId && allRequests.length > 0) {
          const targetRequest = allRequests.find(r => r.id === parseInt(requestId));
          if (targetRequest) {
            setSelectedRequest(targetRequest);
          }
        }
      } finally {
        setLoading(false);
      }
    };
    load();
  }, []);

  // Watch for URL changes to switch conversations dynamically
  useEffect(() => {
    const handleHashChange = () => {
      const hash = window.location.hash;
      const params = new URLSearchParams(hash.split('?')[1]);
      const requestId = params.get('request');
      
      if (requestId && requests.length > 0) {
        const targetRequest = requests.find(r => r.id === parseInt(requestId));
        if (targetRequest && (!selectedRequest || selectedRequest.id !== targetRequest.id)) {
          setSelectedRequest(targetRequest);
        }
      }
    };

    window.addEventListener('hashchange', handleHashChange);
    return () => window.removeEventListener('hashchange', handleHashChange);
  }, [requests, selectedRequest]);

  useEffect(() => {
    if (selectedRequest) {
      loadMessages();
      const interval = setInterval(loadMessages, 5000);
      return () => clearInterval(interval);
    }
  }, [selectedRequest]);

  const loadMessages = async () => {
    if (!selectedRequest) return;
    try {
      const msgs = await window.apiClient.getSwapMessages(selectedRequest.id);
      setMessages(msgs);
      // Scroll to bottom after messages load
      setTimeout(() => {
        const messagesContainer = document.querySelector('.messages-container');
        if (messagesContainer) {
          messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }
      }, 100);
    } catch (e) {
      console.error(e);
    }
  };

  const handleSendMessage = async (e) => {
    e.preventDefault();
    if (!messageText.trim() || !selectedRequest) return;
    setSendingMessage(true);
    try {
      await window.apiClient.sendSwapMessage(selectedRequest.id, messageText);
      setMessageText('');
      await loadMessages();
    } catch (e) {
      console.error(e);
    } finally {
      setSendingMessage(false);
    }
  };

  if (loading) return <Loading />;

  const partner = selectedRequest ? (selectedRequest.sender.id === user.id ? selectedRequest.receiver : selectedRequest.sender) : null;

  return (
    <div className="min-h-screen bg-slate-950">
      <div className="max-w-6xl mx-auto px-4 py-8">
        <h1 className="text-2xl font-bold text-white mb-5">Messages</h1>
        {requests.length === 0 ? (
          <div className="grid md:grid-cols-[300px_1fr] gap-4 h-[70vh]">
            <div className="bg-slate-800/60 border border-slate-700 rounded-xl p-4">
              <p className="text-xs uppercase text-slate-500 mb-3 font-semibold">Conversations</p>
              <div className="text-center py-12 text-slate-500 text-sm">
                No chats yet
              </div>
            </div>
            <div className="bg-slate-800/60 border border-slate-700 rounded-xl p-12 flex flex-col items-center justify-center text-center">
              <div className="text-6xl mb-4">💬</div>
              <h3 className="text-xl font-semibold text-white mb-2">No conversations yet</h3>
              <p className="text-slate-400 mb-6 max-w-md">Start a swap to begin chatting with other users</p>
              <a href="#discover" className="px-6 py-3 bg-gradient-to-r from-brand-600 to-purple-600 text-white font-medium rounded-xl hover:from-brand-500 hover:to-purple-500 transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-brand-500/50">
                → Discover People
              </a>
            </div>
          </div>
        ) : (
          <div className="grid md:grid-cols-[300px_1fr] gap-4 h-[70vh]">
            {/* Conversations List */}
            <div className="bg-slate-800/60 border border-slate-700 rounded-xl p-3 overflow-y-auto">
              <p className="text-xs uppercase text-slate-500 mb-3 font-semibold px-2">Conversations</p>
              {requests.map((r) => {
                const p = r.sender.id === user.id ? r.receiver : r.sender;
                const isSelected = selectedRequest && selectedRequest.id === r.id;
                return (
                  <button 
                    key={r.id} 
                    onClick={() => setSelectedRequest(r)} 
                    className={`w-full text-left p-3 rounded-lg border mb-2 transition-all duration-200 ${isSelected ? 'bg-brand-600/20 border-brand-500' : 'hover:bg-slate-700/40 border-transparent hover:border-slate-600'}`}
                  >
                    <div className="flex items-center gap-3 mb-1">
                      <div className="w-10 h-10 rounded-full bg-gradient-to-br from-brand-500 to-purple-600 flex items-center justify-center text-white text-sm font-semibold">
                        {(p.first_name || 'U')[0].toUpperCase()}
                      </div>
                      <div className="flex-1 min-w-0">
                        <p className="font-medium text-white truncate">{p.first_name || 'User'}</p>
                        <p className="text-xs text-slate-500 truncate">{r.skill_offered} ↔ {r.skill_requested}</p>
                      </div>
                    </div>
                  </button>
                );
              })}
            </div>
            
            {/* Chat Window */}
            {selectedRequest ? (
              <div className="bg-slate-800/60 border border-slate-700 rounded-xl flex flex-col overflow-hidden">
                {/* Chat Header */}
                <div className="p-4 border-b border-slate-700 bg-slate-900/50">
                  <div className="flex items-center gap-3">
                    <div className="w-10 h-10 rounded-full bg-gradient-to-br from-brand-500 to-purple-600 flex items-center justify-center text-white text-sm font-semibold">
                      {(partner.first_name || 'U')[0].toUpperCase()}
                    </div>
                    <div>
                      <h3 className="font-semibold text-white">{partner.first_name || 'User'}</h3>
                      <p className="text-xs text-slate-400">{selectedRequest.skill_offered} ↔ {selectedRequest.skill_requested}</p>
                    </div>
                  </div>
                </div>
                
                {/* Messages */}
                <div className="flex-1 overflow-y-auto p-4 space-y-4 messages-container" style={{scrollBehavior: 'smooth'}}>
                  {messages.length === 0 ? (
                    <div className="text-center text-slate-500 mt-10">No messages yet. Say hi!</div>
                  ) : (
                    messages.map(msg => {
                      const isMe = msg.sender_id === user.id;
                      return (
                        <div key={msg.id} className={`flex flex-col ${isMe ? 'items-end' : 'items-start'} animate-fadeIn`}>
                          <div className={`max-w-[80%] rounded-2xl px-4 py-2 ${isMe ? 'bg-brand-600 text-white rounded-br-none' : 'bg-slate-700 text-slate-200 rounded-bl-none'}`}>
                            {msg.text}
                          </div>
                          <span className="text-[10px] text-slate-500 mt-1">{new Date(msg.created_at).toLocaleTimeString()}</span>
                        </div>
                      );
                    })
                  )}
                  {sendingMessage && (
                    <div className="flex items-center gap-1 text-slate-400 text-sm">
                      <span>Typing</span>
                      <span className="typing-dot"></span>
                      <span className="typing-dot"></span>
                      <span className="typing-dot"></span>
                    </div>
                  )}
                </div>
                
                {/* Message Input */}
                <div className="p-4 border-t border-slate-700 bg-slate-900/50">
                  <form onSubmit={handleSendMessage} className="flex gap-2">
                    <input 
                      type="text" 
                      value={messageText} 
                      onChange={e => setMessageText(e.target.value)} 
                      placeholder="Type a message..." 
                      className="flex-1 px-4 py-2 rounded-full bg-slate-800 border border-slate-700 text-slate-100 focus:outline-none focus:ring-2 focus:ring-brand-500 transition-all" 
                    />
                    <button 
                      type="submit" 
                      disabled={sendingMessage || !messageText.trim()} 
                      className="w-10 h-10 rounded-full bg-brand-600 text-white flex items-center justify-center hover:bg-brand-500 disabled:opacity-50 transition-all hover:scale-110 btn-ripple"
                    >
                      ➤
                    </button>
                  </form>
                </div>
              </div>
            ) : (
              <div className="bg-slate-800/60 border border-slate-700 rounded-xl p-8 text-center text-slate-400 flex items-center justify-center">
                <div>
                  <div className="text-4xl mb-3">👈</div>
                  <p>Select a conversation to start chatting</p>
                </div>
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  );
};

const SettingsPage = () => {
  const [passwords, setPasswords] = useState({ current: '', next: '' });
  const [notificationsEnabled, setNotificationsEnabled] = useState(true);
  const [isPublic, setIsPublic] = useState(true);

  return (
    <div className="min-h-screen bg-slate-950">
      <div className="max-w-3xl mx-auto px-4 py-8 space-y-5">
        <h1 className="text-2xl font-bold text-white">Settings</h1>
        <div className="bg-slate-800/60 border border-slate-700 rounded-xl p-5">
          <h2 className="font-semibold text-white mb-3">Change Password</h2>
          <div className="grid sm:grid-cols-2 gap-3">
            <input type="password" placeholder="Current password" className="px-3 py-2 rounded-lg border border-slate-600 bg-slate-900 text-slate-100" value={passwords.current} onChange={(e) => setPasswords({ ...passwords, current: e.target.value })} />
            <input type="password" placeholder="New password" className="px-3 py-2 rounded-lg border border-slate-600 bg-slate-900 text-slate-100" value={passwords.next} onChange={(e) => setPasswords({ ...passwords, next: e.target.value })} />
          </div>
          <button className="mt-3 px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm hover:bg-indigo-500">Update Password</button>
        </div>
        <div className="bg-slate-800/60 border border-slate-700 rounded-xl p-5">
          <h2 className="font-semibold text-white mb-3">Preferences</h2>
          <label className="flex items-center justify-between py-2">
            <span className="text-sm text-slate-300">Notification preferences</span>
            <input type="checkbox" checked={notificationsEnabled} onChange={(e) => setNotificationsEnabled(e.target.checked)} />
          </label>
          <label className="flex items-center justify-between py-2">
            <span className="text-sm text-slate-300">Public profile</span>
            <input type="checkbox" checked={isPublic} onChange={(e) => setIsPublic(e.target.checked)} />
          </label>
        </div>
        <div className="bg-white border border-red-200 rounded-xl p-5">
          <h2 className="font-semibold text-red-600 mb-3">Danger Zone</h2>
          <button onClick={() => window.confirm('Are you sure you want to delete your account?')} className="px-4 py-2 rounded-lg bg-red-600 text-white text-sm hover:bg-red-500">Delete account</button>
        </div>
      </div>
    </div>
  );
};

// Loading Component
const Loading = () => (
  <div className="flex items-center justify-center min-h-[60vh]">
    <div className="text-center">
      <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-brand-500 mx-auto"></div>
      <p className="mt-4 text-slate-400">Loading...</p>
    </div>
  </div>
);

const Section = ({ title, children, right }) => (
  <div className="bg-slate-800/60 border border-slate-700 rounded-xl p-6 shadow-lg">
    <div className="flex items-center justify-between mb-5">
      <h3 className="text-xl font-semibold text-white">{title}</h3>
      {right}
    </div>
    {children}
  </div>
);

const Stat = ({ label, value, icon }) => (
  <div className="bg-slate-800/60 border border-slate-700 rounded-xl p-5">
    <div className="flex items-center justify-between">
      <div>
        <div className="text-slate-400 text-sm">{label}</div>
        <div className="text-2xl font-semibold text-white">{value}</div>
      </div>
      <div className="w-10 h-10 rounded-lg bg-brand-600/20 text-brand-400 flex items-center justify-center">{icon}</div>
    </div>
  </div>
);

// Table Skeleton Loader
const TableSkeleton = ({ rows = 5 }) => (
  <div className="overflow-x-auto">
    <table className="min-w-full text-sm">
      <thead className="text-slate-400">
        <tr>
          <th className="text-left py-2 pr-3 font-medium"><div className="h-4 animate-shimmer rounded w-20"></div></th>
          <th className="text-left py-2 pr-3 font-medium"><div className="h-4 animate-shimmer rounded w-24"></div></th>
          <th className="text-left py-2 pr-3 font-medium"><div className="h-4 animate-shimmer rounded w-16"></div></th>
          <th className="text-left py-2 font-medium"><div className="h-4 animate-shimmer rounded w-20"></div></th>
        </tr>
      </thead>
      <tbody>
        {Array.from({ length: rows }).map((_, i) => (
          <tr key={i} className="border-t border-slate-700/70">
            <td className="py-3 pr-3"><div className="h-4 animate-shimmer rounded w-32"></div></td>
            <td className="py-3 pr-3"><div className="h-4 animate-shimmer rounded w-40"></div></td>
            <td className="py-3 pr-3"><div className="h-4 animate-shimmer rounded w-20"></div></td>
            <td className="py-3"><div className="h-6 animate-shimmer rounded w-16"></div></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
);

const AdminOverview = () => {
  const [stats, setStats] = useState(null);
  const [loading, setLoading] = useState(true);
  const [users, setUsers] = useState([]);
  const [latest, setLatest] = useState([]);
  const [topSkills, setTopSkills] = useState([]);
  useEffect(() => {
    const load = async () => {
      try {
        const s = await window.apiClient.getAdminStats();
        const u = await window.apiClient.getAdminUsers({ limit: 8 });
        const r = await window.apiClient.getRequests({ page: 1, limit: 5 });
        setStats(s);
        setUsers(u.users || []);
        setLatest(r.requests || []);
        const allSkills = [];
        (u.users || []).forEach(x => {
          (x.skills_offered || []).forEach(s => allSkills.push(s));
          (x.skills_wanted || []).forEach(s => allSkills.push(s));
        });
        const counts = allSkills.reduce((acc, s) => { acc[s] = (acc[s] || 0) + 1; return acc; }, {});
        const sorted = Object.entries(counts).sort((a,b)=>b[1]-a[1]).slice(0,8);
        setTopSkills(sorted);
      } finally {
        setLoading(false);
      }
    };
    load();
  }, []);
  if (loading) return (
    <div className="container mx-auto px-4 py-8 space-y-8">
      <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {Array.from({ length: 4 }).map((_, i) => (
          <div key={i} className="bg-slate-800/60 border border-slate-700 rounded-xl p-5">
            <div className="h-4 animate-shimmer rounded w-24 mb-2"></div>
            <div className="h-8 animate-shimmer rounded w-16"></div>
          </div>
        ))}
      </div>
      <Section title="Recent Users">
        <TableSkeleton rows={8} />
      </Section>
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-4">
        <Section title="Latest Requests">
          <div className="space-y-3">
            {Array.from({ length: 5 }).map((_, i) => (
              <div key={i} className="h-20 animate-shimmer rounded-lg"></div>
            ))}
          </div>
        </Section>
        <Section title="Top Skills">
          <div className="flex flex-wrap gap-2">
            {Array.from({ length: 6 }).map((_, i) => (
              <div key={i} className="h-7 animate-shimmer rounded-full w-20"></div>
            ))}
          </div>
        </Section>
        <Section title="System Health">
          <div className="space-y-3">
            {Array.from({ length: 3 }).map((_, i) => (
              <div key={i} className="h-16 animate-shimmer rounded-lg"></div>
            ))}
          </div>
        </Section>
      </div>
    </div>
  );
  return (
    <div className="container mx-auto px-4 py-8 space-y-8">
      <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <Stat label="Total Users" value={stats.totalUsers} icon={<span>👥</span>} />
        <Stat label="Active Users" value={stats.activeUsers} icon={<span>✅</span>} />
        <Stat label="Total Requests" value={stats.totalRequests} icon={<span>🔄</span>} />
        <Stat label="Completed" value={stats.completedRequests} icon={<span>🏁</span>} />
      </div>
      <Section title="Recent Users">
        <div className="overflow-x-auto">
          <table className="min-w-full text-sm">
            <thead className="text-slate-400">
              <tr>
                <th className="text-left py-2 pr-3 font-medium">User</th>
                <th className="text-left py-2 pr-3 font-medium">Email</th>
                <th className="text-left py-2 pr-3 font-medium">Role</th>
                <th className="text-left py-2 font-medium">Status</th>
              </tr>
            </thead>
            <tbody className="text-slate-200">
              {users.map(u => (
                <tr key={u.id} className="border-t border-slate-700/70 hover:bg-slate-800/30 transition-colors">
                  <td className="py-3 pr-3">
                    <div className="flex items-center gap-3">
                      <div className="w-8 h-8 rounded-full bg-gradient-to-br from-brand-500 to-purple-600 flex items-center justify-center text-white text-xs font-semibold">
                        {(u.first_name || 'U')[0].toUpperCase()}
                      </div>
                      <span>{u.first_name || 'User'}</span>
                    </div>
                  </td>
                  <td className="py-3 pr-3">{u.email}</td>
                  <td className="py-3 pr-3">{u.role}</td>
                  <td className="py-3">{u.is_blocked ? <span className="px-2 py-1 rounded bg-red-500/20 text-red-300">🔴 Blocked</span> : <span className="px-2 py-1 rounded bg-green-500/20 text-green-300">🟢 Active</span>}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </Section>
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-4">
        <Section title="Latest Requests">
          <div className="space-y-3">
            {latest.map(r => (
              <div key={r.id} className="p-3 rounded-lg bg-slate-900/60 border border-slate-700 hover:border-slate-600 transition-colors">
                <div className="text-sm space-y-1">
                  <div className="flex items-center gap-2 text-slate-200">
                    <span className="font-medium">{r.sender.first_name || 'User'}</span>
                    <span className="text-slate-500">→</span>
                    <span className="font-medium">{r.receiver.first_name || 'User'}</span>
                  </div>
                  <div className="text-slate-400 text-xs">
                    <span className="text-brand-400">{r.skill_offered}</span>
                    <span className="mx-1">↔</span>
                    <span className="text-purple-400">{r.skill_requested}</span>
                  </div>
                  <div className="pt-1">
                    <span className={`px-2 py-1 rounded text-xs ${
                      r.status === 'pending' ? 'bg-yellow-500/20 text-yellow-300' :
                      r.status === 'accepted' ? 'bg-green-500/20 text-green-300' :
                      r.status === 'rejected' ? 'bg-red-500/20 text-red-300' :
                      'bg-slate-600/30 text-slate-200'
                    }`}>{r.status}</span>
                  </div>
                </div>
              </div>
            ))}
            {latest.length === 0 && <div className="text-slate-400 text-sm">No recent requests</div>}
          </div>
        </Section>
        <Section title="Top Skills" >
          <div className="flex flex-wrap gap-2">
            {topSkills.map(([skill, count])=>(
              <span key={skill} className="px-3 py-1 rounded-full bg-brand-600/20 text-brand-300 text-sm">{skill} <span className="opacity-70">({count})</span></span>
            ))}
            {topSkills.length === 0 && (
              <div className="text-center py-6 w-full">
                <div className="text-4xl mb-2">📊</div>
                <div className="text-slate-400 text-sm">No skill activity yet</div>
              </div>
            )}
          </div>
        </Section>
        <Section title="System Health">
          <div className="space-y-3">
            <div className="p-3 rounded-lg bg-yellow-500/10 border border-yellow-500/30 hover:bg-yellow-500/15 transition-colors">
              <div className="flex items-center justify-between">
                <div className="flex items-center gap-2">
                  <span className="text-2xl">⏳</span>
                  <span className="text-sm text-slate-300">Pending</span>
                </div>
                <span className="text-xl font-semibold text-yellow-300">{stats.pendingRequests}</span>
              </div>
            </div>
            <div className="p-3 rounded-lg bg-green-500/10 border border-green-500/30 hover:bg-green-500/15 transition-colors">
              <div className="flex items-center justify-between">
                <div className="flex items-center gap-2">
                  <span className="text-2xl">✅</span>
                  <span className="text-sm text-slate-300">Completed</span>
                </div>
                <span className="text-xl font-semibold text-green-300">{stats.completedRequests}</span>
              </div>
            </div>
            <div className="p-3 rounded-lg bg-red-500/10 border border-red-500/30 hover:bg-red-500/15 transition-colors">
              <div className="flex items-center justify-between">
                <div className="flex items-center gap-2">
                  <span className="text-2xl">🚫</span>
                  <span className="text-sm text-slate-300">Blocked</span>
                </div>
                <span className="text-xl font-semibold text-red-300">{stats.blockedUsers}</span>
              </div>
            </div>
          </div>
        </Section>
      </div>
    </div>
  );
};

const AdminUsers = () => {
  const [query, setQuery] = useState('');
  const [users, setUsers] = useState([]);
  const [loading, setLoading] = useState(false);
  const [adding, setAdding] = useState(false);
  const [page, setPage] = useState(1);
  const [limit, setLimit] = useState(25);
  const [total, setTotal] = useState(0);
  const [form, setForm] = useState({ name: '', email: '', password: '', role: 'user' });
  
  const load = async () => {
    setLoading(true);
    try {
      const resp = await window.apiClient.getAdminUsers({ search: query, page, limit });
      setUsers(resp.users || []);
      setTotal(resp.total || 0);
    } finally {
      setLoading(false);
    }
  };
  
  useEffect(() => { load(); }, [page, limit]);
  
  const toggleBlock = async (u) => {
    try {
      if (u.is_blocked) {
        await window.apiClient.unblockUser(u.id);
      } else {
        await window.apiClient.blockUser(u.id);
      }
      load();
    } catch (e) {
      alert('Failed to update user: ' + e.message);
    }
  };
  
  const delUser = async (u) => {
    if (!confirm(`Delete user ${u.first_name || u.email}?`)) return;
    try {
      await window.apiClient.deleteUser(u.id);
      load();
    } catch (e) {
      alert('Failed to delete user: ' + e.message);
    }
  };
  
  const addUser = async () => {
    try {
      await window.apiClient.createAdminUser(form);
      setAdding(false);
      setForm({ name: '', email: '', password: '', role: 'user' });
      load();
    } catch (e) {
      alert('Failed to create user: ' + e.message);
    }
  };
  
  const totalPages = Math.ceil(total / limit);
  
  return (
    <div className="container mx-auto px-4 py-8 space-y-6 animate-fadeIn">
      <div className="flex items-center justify-between mb-6">
        <h1 className="text-2xl font-bold text-white">User Management</h1>
        <div className="flex items-center gap-3">
          <button onClick={()=>setAdding(true)} className="px-4 py-2 rounded-lg bg-brand-600 hover:bg-brand-500 text-white font-medium transition-all shadow-lg shadow-brand-500/20 flex items-center gap-2 btn-ripple">
            <svg className="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M8 9a3 3 0 100-6 3 3 0 000 6zM8 11a6 6 0 016 6H2a6 6 0 016-6zM16 7a1 1 0 10-2 0v1h-1a1 1 0 100 2h1v1a1 1 0 102 0v-1h1a1 1 0 100-2h-1V7z"/></svg>
            Add User
          </button>
          <div className="flex items-center gap-2">
            <input value={query} onChange={(e)=>setQuery(e.target.value)} onKeyPress={(e) => e.key === 'Enter' && load()} placeholder="Search users..." className="px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 text-slate-100 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500 transition-all w-64"/>
            <button onClick={load} className="px-4 py-2 rounded-lg bg-slate-700 hover:bg-slate-600 text-white transition-all btn-ripple">
              <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
            </button>
          </div>
        </div>
      </div>

      {adding && (
        <div className="mb-6 p-6 rounded-xl bg-slate-800/60 border border-slate-700 animate-fadeIn">
          <h3 className="text-lg font-semibold text-white mb-4">Create New User</h3>
          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <input value={form.name} onChange={e=>setForm({...form, name:e.target.value})} placeholder="Full name" className="px-4 py-2 rounded-lg bg-slate-900 border border-slate-700 text-slate-100 focus:ring-2 focus:ring-brand-500 transition-all"/>
            <input value={form.email} onChange={e=>setForm({...form, email:e.target.value})} placeholder="Email" type="email" className="px-4 py-2 rounded-lg bg-slate-900 border border-slate-700 text-slate-100 focus:ring-2 focus:ring-brand-500 transition-all"/>
            <input value={form.password} onChange={e=>setForm({...form, password:e.target.value})} placeholder="Password" type="password" className="px-4 py-2 rounded-lg bg-slate-900 border border-slate-700 text-slate-100 focus:ring-2 focus:ring-brand-500 transition-all"/>
            <select value={form.role} onChange={e=>setForm({...form, role:e.target.value})} className="px-4 py-2 rounded-lg bg-slate-900 border border-slate-700 text-slate-100 focus:ring-2 focus:ring-brand-500 transition-all">
              <option value="user">User</option>
              <option value="admin">Admin</option>
            </select>
          </div>
          <div className="mt-4 flex gap-3">
            <button onClick={addUser} className="px-6 py-2 rounded-lg bg-brand-600 hover:bg-brand-500 text-white font-medium transition-all btn-ripple">Create User</button>
            <button onClick={()=>setAdding(false)} className="px-6 py-2 rounded-lg bg-slate-700 hover:bg-slate-600 text-white transition-all btn-ripple">Cancel</button>
          </div>
        </div>
      )}

      <div className="bg-slate-800/60 border border-slate-700 rounded-xl overflow-hidden">
        <div className="p-4 border-b border-slate-700 flex items-center justify-between bg-slate-900/50">
          <span className="text-slate-300 text-sm">Showing {users.length} of {total} users</span>
          <select value={limit} onChange={e => {setLimit(Number(e.target.value)); setPage(1);}} className="px-3 py-1 rounded-lg bg-slate-800 border border-slate-700 text-slate-100 text-sm">
            <option value="10">10 per page</option>
            <option value="25">25 per page</option>
            <option value="50">50 per page</option>
            <option value="100">100 per page</option>
          </select>
        </div>
        
        {loading ? (
          <div className="p-12"><Loading/></div>
        ) : (
          <div className="overflow-x-auto">
            <table className="min-w-full">
              <thead className="bg-slate-900/50">
                <tr>
                  <th className="text-left py-4 px-6 font-semibold text-slate-300 text-sm">User</th>
                  <th className="text-left py-4 px-6 font-semibold text-slate-300 text-sm">Email</th>
                  <th className="text-center py-4 px-6 font-semibold text-slate-300 text-sm">Role</th>
                  <th className="text-center py-4 px-6 font-semibold text-slate-300 text-sm">Status</th>
                  <th className="text-center py-4 px-6 font-semibold text-slate-300 text-sm">Actions</th>
                </tr>
              </thead>
              <tbody className="text-slate-200">
                {users.map(u => (
                  <tr key={u.id} className="border-t border-slate-700/50 hover:bg-slate-700/30 transition-colors">
                    <td className="py-4 px-6">
                      <div className="flex items-center gap-3">
                        <div className="w-10 h-10 rounded-full bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center text-white font-semibold">
                          {(u.first_name || u.email)?.[0]?.toUpperCase()}
                        </div>
                        <span className="font-medium">{u.first_name || 'User'}</span>
                      </div>
                    </td>
                    <td className="py-4 px-6 text-slate-300">{u.email}</td>
                    <td className="py-4 px-6 text-center">
                      <span className={`px-3 py-1 rounded-full text-xs font-semibold ${u.role === 'admin' ? 'bg-purple-500/20 text-purple-300 border border-purple-500/30' : 'bg-slate-700 text-slate-300'}`}>
                        {u.role}
                      </span>
                    </td>
                    <td className="py-4 px-6 text-center">
                      {u.is_blocked ? (
                        <span className="px-3 py-1 rounded-full bg-red-500/20 text-red-300 text-xs font-semibold border border-red-500/30 inline-flex items-center gap-1">
                          🔴 Blocked
                        </span>
                      ) : (
                        <span className="px-3 py-1 rounded-full bg-green-500/20 text-green-300 text-xs font-semibold border border-green-500/30 inline-flex items-center gap-1">
                          🟢 Active
                        </span>
                      )}
                    </td>
                    <td className="py-4 px-6">
                      <div className="flex items-center justify-center gap-2">
                        <button onClick={()=>toggleBlock(u)} className={`px-3 py-1.5 rounded-lg text-xs font-medium transition-all hover:scale-105 flex items-center gap-1 ${u.is_blocked ? 'bg-green-600/20 text-green-300 hover:bg-green-600 hover:text-white border border-green-500/30' : 'bg-yellow-600/20 text-yellow-300 hover:bg-yellow-600 hover:text-white border border-yellow-500/30'}`}>
                          {u.is_blocked ? '✓ Unblock' : '🚫 Block'}
                        </button>
                        <button onClick={()=>delUser(u)} className="px-3 py-1.5 rounded-lg bg-red-600/20 text-red-300 hover:bg-red-600 hover:text-white text-xs font-medium transition-all hover:scale-105 border border-red-500/30 flex items-center gap-1">
                          🗑 Delete
                        </button>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}

        {/* Pagination */}
        {totalPages > 1 && (
          <div className="p-4 border-t border-slate-700 flex items-center justify-between bg-slate-900/50">
            <button onClick={() => setPage(p => Math.max(1, p - 1))} disabled={page === 1} className="px-4 py-2 rounded-lg bg-slate-700 hover:bg-slate-600 text-white disabled:opacity-50 disabled:cursor-not-allowed transition-all">
              Previous
            </button>
            <div className="flex items-center gap-2">
              {Array.from({ length: Math.min(5, totalPages) }, (_, i) => {
                const pageNum = i + 1;
                return (
                  <button key={pageNum} onClick={() => setPage(pageNum)} className={`w-10 h-10 rounded-lg font-medium transition-all ${page === pageNum ? 'bg-brand-600 text-white' : 'bg-slate-700 text-slate-300 hover:bg-slate-600'}`}>
                    {pageNum}
                  </button>
                );
              })}
              {totalPages > 5 && <span className="text-slate-500">...</span>}
              {totalPages > 5 && (
                <button onClick={() => setPage(totalPages)} className={`w-10 h-10 rounded-lg font-medium transition-all ${page === totalPages ? 'bg-brand-600 text-white' : 'bg-slate-700 text-slate-300 hover:bg-slate-600'}`}>
                  {totalPages}
                </button>
              )}
            </div>
            <button onClick={() => setPage(p => Math.min(totalPages, p + 1))} disabled={page === totalPages} className="px-4 py-2 rounded-lg bg-slate-700 hover:bg-slate-600 text-white disabled:opacity-50 disabled:cursor-not-allowed transition-all">
              Next
            </button>
          </div>
        )}
      </div>
    </div>
  );
};

const AdminStats = () => {
  const [stats, setStats] = useState(null);
  const [timeframe, setTimeframe] = useState('30');
  const [activityData, setActivityData] = useState([]);
  
  useEffect(() => {
    const load = async () => {
      const s = await window.apiClient.getAdminStats();
      setStats(s);
      
      // Generate mock activity data based on timeframe
      const days = parseInt(timeframe);
      const data = Array.from({ length: days }, (_, i) => {
        const date = new Date();
        date.setDate(date.getDate() - (days - i - 1));
        return {
          date: date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }),
          count: Math.floor(Math.random() * 20) + 5
        };
      });
      setActivityData(data);
    };
    load();
  }, [timeframe]);
  
  if (!stats) return <Loading/>;
  
  const maxActivity = Math.max(...activityData.map(d => d.count));
  
  return (
    <div className="container mx-auto px-4 py-8 space-y-8 animate-fadeIn">
      <div className="flex items-center justify-between">
        <h1 className="text-2xl font-bold text-white">Platform Statistics</h1>
        <select value={timeframe} onChange={e => setTimeframe(e.target.value)} className="px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 text-slate-100 focus:ring-2 focus:ring-brand-500">
          <option value="7">Last 7 days</option>
          <option value="30">Last 30 days</option>
          <option value="90">Last 3 months</option>
        </select>
      </div>

      {/* Stats Grid - 3 columns */}
      <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div className="bg-slate-800/60 border border-slate-700 rounded-xl p-6 hover-lift transition-all">
          <div className="flex items-center justify-between mb-4">
            <div>
              <div className="text-slate-400 text-sm font-medium mb-1">Total Users</div>
              <div className="text-3xl font-bold text-white">{stats.totalUsers}</div>
            </div>
            <div className="w-14 h-14 rounded-xl bg-blue-500/20 flex items-center justify-center text-3xl">
              👥
            </div>
          </div>
          <div className="text-xs text-slate-500">All registered users</div>
        </div>

        <div className="bg-slate-800/60 border border-slate-700 rounded-xl p-6 hover-lift transition-all">
          <div className="flex items-center justify-between mb-4">
            <div>
              <div className="text-slate-400 text-sm font-medium mb-1">Active Users</div>
              <div className="text-3xl font-bold text-green-400">{stats.activeUsers}</div>
            </div>
            <div className="w-14 h-14 rounded-xl bg-green-500/20 flex items-center justify-center text-3xl">
              ✅
            </div>
          </div>
          <div className="text-xs text-green-500/70">{Math.round((stats.activeUsers / stats.totalUsers) * 100)}% of total</div>
        </div>

        <div className="bg-slate-800/60 border border-slate-700 rounded-xl p-6 hover-lift transition-all">
          <div className="flex items-center justify-between mb-4">
            <div>
              <div className="text-slate-400 text-sm font-medium mb-1">Blocked Users</div>
              <div className="text-3xl font-bold text-red-400">{stats.blockedUsers}</div>
            </div>
            <div className="w-14 h-14 rounded-xl bg-red-500/20 flex items-center justify-center text-3xl">
              ⛔
            </div>
          </div>
          <div className="text-xs text-red-500/70">{Math.round((stats.blockedUsers / stats.totalUsers) * 100)}% of total</div>
        </div>

        <div className="bg-slate-800/60 border border-slate-700 rounded-xl p-6 hover-lift transition-all">
          <div className="flex items-center justify-between mb-4">
            <div>
              <div className="text-slate-400 text-sm font-medium mb-1">Total Requests</div>
              <div className="text-3xl font-bold text-brand-400">{stats.totalRequests}</div>
            </div>
            <div className="w-14 h-14 rounded-xl bg-brand-500/20 flex items-center justify-center text-3xl">
              🔄
            </div>
          </div>
          <div className="text-xs text-slate-500">All swap requests</div>
        </div>

        <div className="bg-slate-800/60 border border-slate-700 rounded-xl p-6 hover-lift transition-all">
          <div className="flex items-center justify-between mb-4">
            <div>
              <div className="text-slate-400 text-sm font-medium mb-1">Pending Requests</div>
              <div className="text-3xl font-bold text-yellow-400">{stats.pendingRequests}</div>
            </div>
            <div className="w-14 h-14 rounded-xl bg-yellow-500/20 flex items-center justify-center text-3xl">
              ⏳
            </div>
          </div>
          <div className="text-xs text-yellow-500/70">{Math.round((stats.pendingRequests / stats.totalRequests) * 100)}% pending</div>
        </div>

        <div className="bg-slate-800/60 border border-slate-700 rounded-xl p-6 hover-lift transition-all">
          <div className="flex items-center justify-between mb-4">
            <div>
              <div className="text-slate-400 text-sm font-medium mb-1">Completed Swaps</div>
              <div className="text-3xl font-bold text-green-400">{stats.completedRequests}</div>
            </div>
            <div className="w-14 h-14 rounded-xl bg-green-500/20 flex items-center justify-center text-3xl">
              🏁
            </div>
          </div>
          <div className="text-xs text-green-500/70">{Math.round((stats.completedRequests / stats.totalRequests) * 100)}% success rate</div>
        </div>
      </div>

      {/* Activity Chart */}
      <div className="bg-slate-800/60 border border-slate-700 rounded-xl p-6">
        <h3 className="text-lg font-semibold text-white mb-6">Activity Overview</h3>
        <div className="relative">
          {/* Y-axis labels */}
          <div className="absolute left-0 top-0 bottom-8 flex flex-col justify-between text-xs text-slate-500 pr-2">
            <span>{maxActivity}</span>
            <span>{Math.floor(maxActivity / 2)}</span>
            <span>0</span>
          </div>
          
          {/* Chart */}
          <div className="ml-8 mb-8">
            <div className="grid gap-2 h-48 items-end" style={{gridTemplateColumns: `repeat(${activityData.length}, minmax(0, 1fr))`}}>
              {activityData.map((item, i) => (
                <div key={i} className="relative group">
                  <div 
                    className="bg-gradient-to-t from-brand-600 to-brand-400 hover:from-brand-500 hover:to-brand-300 transition-all rounded-t cursor-pointer"
                    style={{height: `${(item.count / maxActivity) * 100}%`}}
                  >
                    {/* Tooltip */}
                    <div className="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-3 py-2 bg-slate-900 border border-slate-700 rounded-lg text-xs text-white opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none z-10">
                      <div className="font-semibold">{item.count} activities</div>
                      <div className="text-slate-400">{item.date}</div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
          
          {/* X-axis labels */}
          <div className="ml-8 grid gap-2 text-xs text-slate-500" style={{gridTemplateColumns: `repeat(${activityData.length}, minmax(0, 1fr))`}}>
            {activityData.map((item, i) => (
              i % Math.ceil(activityData.length / 8) === 0 ? (
                <span key={i} className="text-center">{item.date}</span>
              ) : <span key={i}></span>
            ))}
          </div>
        </div>
      </div>

      {/* Quick Stats Row */}
      <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div className="bg-slate-800/40 border border-slate-700 rounded-lg p-4 text-center">
          <div className="text-2xl font-bold text-white">{Math.round((stats.completedRequests / stats.totalRequests) * 100)}%</div>
          <div className="text-xs text-slate-400 mt-1">Success Rate</div>
        </div>
        <div className="bg-slate-800/40 border border-slate-700 rounded-lg p-4 text-center">
          <div className="text-2xl font-bold text-white">{(stats.totalRequests / stats.activeUsers).toFixed(1)}</div>
          <div className="text-xs text-slate-400 mt-1">Avg Requests/User</div>
        </div>
        <div className="bg-slate-800/40 border border-slate-700 rounded-lg p-4 text-center">
          <div className="text-2xl font-bold text-white">{stats.totalUsers - stats.blockedUsers}</div>
          <div className="text-xs text-slate-400 mt-1">Healthy Users</div>
        </div>
        <div className="bg-slate-800/40 border border-slate-700 rounded-lg p-4 text-center">
          <div className="text-2xl font-bold text-white">{Math.round((stats.pendingRequests / stats.totalRequests) * 100)}%</div>
          <div className="text-xs text-slate-400 mt-1">Pending Rate</div>
        </div>
      </div>
    </div>
  );
};

// Removed SkillSwapComponents export

// Main App Component
const { useRef } = React;

// Swap Request Modal Component
const SwapRequestModal = ({ isOpen, onClose, userItem, onSubmit }) => {
  const [skillOffered, setSkillOffered] = useState('');
  const [skillRequested, setSkillRequested] = useState('');
  const [message, setMessage] = useState('');

  useEffect(() => {
    if (isOpen) {
      setSkillOffered(userItem.skills_wanted && userItem.skills_wanted.length > 0 ? userItem.skills_wanted[0] : '');
      setSkillRequested(userItem.skills_offered && userItem.skills_offered.length > 0 ? userItem.skills_offered[0] : '');
      setMessage('');
      document.body.style.overflow = 'hidden';
    } else {
      document.body.style.overflow = 'auto';
    }
    return () => {
      document.body.style.overflow = 'auto';
    };
  }, [isOpen, userItem]);

  useEffect(() => {
    if (!isOpen) return;
    const handleEsc = (e) => {
      if (e.key === 'Escape') onClose();
    };
    window.addEventListener('keydown', handleEsc);
    return () => window.removeEventListener('keydown', handleEsc);
  }, [isOpen, onClose]);

  if (!isOpen) return null;

  return (
    <ModalPortal>
      <div className="modal-overlay">
        <div className="modal-backdrop bg-black/60 backdrop-blur-sm animate-fadeIn" onClick={onClose}></div>
        <div className="modal-content bg-slate-800 border border-slate-700 rounded-2xl shadow-2xl animate-scaleIn overflow-hidden" style={{ width: '100%', maxWidth: '28rem' }}>
          <div className="bg-gradient-to-r from-brand-600 to-purple-600 px-6 py-4">
            <h3 className="text-xl font-semibold text-white">Request Swap with {userItem.first_name}</h3>
          </div>
          <div className="p-6 space-y-5">
            <div>
              <label className="block text-sm font-semibold text-slate-300 mb-2">I will offer:</label>
              <input type="text" className="w-full px-4 py-3 rounded-xl bg-slate-900/70 border border-slate-700 text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all"
                     value={skillOffered} onChange={(e) => setSkillOffered(e.target.value)} placeholder="e.g. JavaScript" />
            </div>
            <div>
              <label className="block text-sm font-semibold text-slate-300 mb-2">I want to learn:</label>
              <input type="text" className="w-full px-4 py-3 rounded-xl bg-slate-900/70 border border-slate-700 text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all"
                     value={skillRequested} onChange={(e) => setSkillRequested(e.target.value)} placeholder="e.g. Python" />
            </div>
            <div>
              <label className="block text-sm font-semibold text-slate-300 mb-2">Message (optional):</label>
              <textarea className="w-full px-4 py-3 rounded-xl bg-slate-900/70 border border-slate-700 text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all resize-none"
                        rows="3" value={message} onChange={(e) => setMessage(e.target.value)} placeholder="Hi, let's swap skills!"></textarea>
            </div>
            <div className="flex gap-3 pt-2">
              <button onClick={onClose} className="flex-1 px-4 py-3 rounded-xl bg-slate-700 text-slate-300 hover:bg-slate-600 transition-all duration-200 font-medium btn-ripple">Cancel</button>
              <button onClick={() => onSubmit(skillOffered, skillRequested, message)}
                      className="flex-1 px-4 py-3 rounded-xl bg-gradient-to-r from-brand-600 to-purple-600 text-white hover:from-brand-500 hover:to-purple-500 transition-all duration-200 hover:shadow-lg hover:shadow-brand-500/30 font-semibold btn-ripple disabled:opacity-50 disabled:cursor-not-allowed"
                      disabled={!skillOffered || !skillRequested}>Send Request</button>
            </div>
          </div>
        </div>
      </div>
    </ModalPortal>
  );
};

// User Detail Modal Component
const UserDetailModal = ({ isOpen, onClose, userItem, onSwapRequest }) => {
    useEffect(() => {
        if (isOpen) {
            document.body.style.overflow = 'hidden';
        } else {
            document.body.style.overflow = 'auto';
        }
        return () => {
            document.body.style.overflow = 'auto';
        };
    }, [isOpen]);

    useEffect(() => {
        if (!isOpen) return;
        const handleEsc = (e) => {
            if (e.key === 'Escape') onClose();
        };
        window.addEventListener('keydown', handleEsc);
        return () => window.removeEventListener('keydown', handleEsc);
    }, [isOpen, onClose]);

    if (!isOpen || !userItem) return null;

    return (
        <div style={{ position: 'fixed', top: 0, left: 0, right: 0, bottom: 0, zIndex: 9999, display: 'flex', alignItems: 'center', justifyContent: 'center', padding: '1rem' }}>
            <div className="absolute inset-0 bg-black/60 backdrop-blur-sm animate-fadeIn" onClick={onClose}></div>
            <div className="bg-slate-800 border border-slate-700 rounded-2xl shadow-2xl animate-scaleIn" style={{ position: 'relative', width: '100%', maxWidth: '42rem', maxHeight: '90vh', overflowY: 'auto', zIndex: 10000 }}>
                <div className="p-6">
                <button onClick={onClose} className="absolute top-4 right-4 text-slate-400 hover:text-white z-10">
                    <svg className="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
                <div className="flex items-center gap-6 mb-6">
                    {userItem.profile_image ? (
                        <img src={userItem.profile_image} alt={userItem.first_name} className="w-20 h-20 rounded-full object-cover border-2 border-brand-500" />
                    ) : (
                        <div className="w-20 h-20 bg-gradient-to-br from-brand-500 to-brand-700 rounded-full flex items-center justify-center text-white font-bold text-2xl border-2 border-brand-500">
                            {userItem.first_name ? userItem.first_name[0].toUpperCase() : 'U'}
                        </div>
                    )}
                    <div>
                        <h2 className="text-2xl font-bold text-white">{userItem.first_name || 'Unknown'}</h2>
                        <p className="text-slate-400">{userItem.location || 'Unknown Location'}</p>
                        <div className="flex items-center gap-1 text-yellow-400 mt-1">
                            <span>⭐</span>
                            <span className="font-semibold">{userItem.rating ? userItem.rating.toFixed(1) : 'New'}</span>
                            <span className="text-slate-500 text-sm">({userItem.rating_count || 0} reviews)</span>
                        </div>
                    </div>
                </div>
                
                {userItem.bio && (
                    <div className="mb-6">
                        <h3 className="font-semibold text-slate-300 mb-2">About Me</h3>
                        <p className="text-slate-400 bg-slate-900/50 p-4 rounded-xl border border-slate-700/50">{userItem.bio}</p>
                    </div>
                )}
                
                <div className="grid md:grid-cols-2 gap-6 mb-6">
                    <div>
                        <h3 className="font-semibold text-slate-300 mb-3">Skills Offered</h3>
                        <div className="flex flex-wrap gap-2">
                            {userItem.skills_offered?.map((s, i) => (
                                <span key={i} className="bg-green-500/10 text-green-400 px-3 py-1 rounded-full text-sm border border-green-500/20">{s}</span>
                            ))}
                        </div>
                    </div>
                    <div>
                        <h3 className="font-semibold text-slate-300 mb-3">Skills Wanted</h3>
                        <div className="flex flex-wrap gap-2">
                            {userItem.skills_wanted?.map((s, i) => (
                                <span key={i} className="bg-brand-500/10 text-brand-400 px-3 py-1 rounded-full text-sm border border-brand-500/20">{s}</span>
                            ))}
                        </div>
                    </div>
                </div>

                {userItem.reviews && userItem.reviews.length > 0 && (
                    <div className="mb-6">
                        <h3 className="font-semibold text-slate-300 mb-3">Recent Reviews</h3>
                        <div className="space-y-3 max-h-40 overflow-y-auto pr-2">
                            {userItem.reviews.map((rev) => (
                                <div key={rev.id} className="bg-slate-900/50 p-3 rounded-lg border border-slate-700/50">
                                    <div className="flex justify-between items-center mb-1">
                                        <span className="font-medium text-slate-200">{rev.reviewer_name}</span>
                                        <span className="text-yellow-400 text-sm">{"⭐".repeat(rev.rating)}</span>
                                    </div>
                                    <p className="text-slate-400 text-sm">{rev.text}</p>
                                </div>
                            ))}
                        </div>
                    </div>
                )}

                <button onClick={() => { onClose(); onSwapRequest(userItem); }}
                    className="w-full bg-gradient-to-r from-brand-600 to-purple-600 text-white py-3 rounded-xl hover:from-brand-500 hover:to-purple-500 transition-all duration-300 font-semibold shadow-lg shadow-brand-500/20 hover:shadow-brand-500/40 btn-ripple">
                    Request Swap
                </button>
                </div>
            </div>
        </div>
    );
};

// Skeleton Loader
const UserCardSkeleton = () => (
    <div className="bg-slate-800/40 border border-slate-700/50 rounded-2xl shadow-md p-6 h-full flex flex-col">
        <div className="flex items-center mb-5">
            <div className="w-14 h-14 rounded-full animate-shimmer"></div>
            <div className="ml-4 space-y-2 flex-1">
                <div className="h-4 animate-shimmer rounded w-24"></div>
                <div className="h-3 animate-shimmer rounded w-32"></div>
            </div>
        </div>
        <div className="space-y-2 mb-5">
            <div className="h-3 animate-shimmer rounded w-full"></div>
            <div className="h-3 animate-shimmer rounded w-4/5"></div>
        </div>
        <div className="mt-auto space-y-4">
            <div>
                <div className="h-3 animate-shimmer rounded w-16 mb-2"></div>
                <div className="flex gap-2">
                    <div className="h-5 animate-shimmer rounded w-16"></div>
                    <div className="h-5 animate-shimmer rounded w-20"></div>
                </div>
            </div>
            <div className="h-10 animate-shimmer rounded-xl w-full mt-4"></div>
        </div>
    </div>
);

// Empty State Component
const EmptyState = ({ icon, title, description }) => (
    <div className="text-center py-16 bg-slate-800/40 border border-slate-700/50 rounded-2xl my-6 flex flex-col items-center justify-center">
        <div className="text-5xl mb-4">{icon}</div>
        <h3 className="text-xl font-bold text-white mb-2">{title}</h3>
        <p className="text-slate-400 max-w-md mx-auto">{description}</p>
    </div>
);

// Discover Page Component
const DiscoverPage = () => {
    const [users, setUsers] = useState([]);
    const [recommendedUsers, setRecommendedUsers] = useState([]);
    const [search, setSearch] = useState('');
    const [debouncedSearch, setDebouncedSearch] = useState('');
    const [skillFilter, setSkillFilter] = useState('');
    const [skillCategory, setSkillCategory] = useState('');
    const [sort, setSort] = useState('');
    const [availability, setAvailability] = useState('');
    const [location, setLocation] = useState('');
    const [minRating, setMinRating] = useState('');
    const [loading, setLoading] = useState(false);
    const [page, setPage] = useState(1);
    const [hasMore, setHasMore] = useState(true);
    const [requestModal, setRequestModal] = useState({ open: false, user: null });
    const [toast, setToast] = useState({ show: false, message: '', type: 'success' });
    const [viewMode, setViewMode] = useState('grid'); // 'grid' or 'list'
    const [showFilters, setShowFilters] = useState(true);
    const [showScrollTop, setShowScrollTop] = useState(false);
    const [recentlyViewed, setRecentlyViewed] = useState([]);
    const [savedForLater, setSavedForLater] = useState([]);
    const [totalUsers, setTotalUsers] = useState(0);
    const [quickViewUser, setQuickViewUser] = useState(null);
    const [filterSections, setFilterSections] = useState({
        skills: true,
        location: true,
        availability: true,
        rating: true
    });
    const searchInputRef = useRef(null);
    const { user } = useAuth();
    
    const skillCategories = ['All', 'Tech', 'Design', 'Business', 'Languages', 'Marketing', 'Music', 'Sports'];
    const popularSkills = ['JavaScript', 'Python', 'Design', 'Marketing'];
    const safeReadArray = (key) => {
        try {
            const raw = localStorage.getItem(key);
            if (!raw) return [];
            const parsed = JSON.parse(raw);
            return Array.isArray(parsed) ? parsed : [];
        } catch (e) {
            console.warn(`Invalid localStorage value for ${key}:`, e);
            return [];
        }
    };
    
    // Debounce search input (300ms delay)
    useEffect(() => {
        const timer = setTimeout(() => {
            setDebouncedSearch(search);
        }, 300);
        return () => clearTimeout(timer);
    }, [search]);
    
    // Setup intersection observer for infinite scrolling
    const observer = useRef();
    const lastUserElementRef = (node) => {
        if (loading) return;
        if (observer.current) observer.current.disconnect();
        observer.current = new IntersectionObserver(entries => {
            if (entries[0].isIntersecting && hasMore) {
                setPage(prevPage => prevPage + 1);
            }
        });
        if (node) observer.current.observe(node);
    };

    // Load recently viewed from localStorage
    useEffect(() => {
        const viewed = safeReadArray('recentlyViewed');
        setRecentlyViewed(viewed.slice(0, 4));
        const saved = safeReadArray('savedForLaterUsers');
        setSavedForLater(saved);
    }, []);

    useEffect(() => {
        const storedSearch = localStorage.getItem('globalUserSearch');
        if (storedSearch) {
            setSearch(storedSearch);
            localStorage.removeItem('globalUserSearch');
        }
        const handler = (e) => {
            const query = (e.detail || '').trim();
            if (query) setSearch(query);
        };
        window.addEventListener('skillswap-search', handler);
        return () => window.removeEventListener('skillswap-search', handler);
    }, []);

    useEffect(() => {
        const handleSlashShortcut = (e) => {
            if (e.key === '/' && document.activeElement?.tagName !== 'INPUT' && document.activeElement?.tagName !== 'TEXTAREA') {
                e.preventDefault();
                searchInputRef.current?.focus();
            }
        };
        window.addEventListener('keydown', handleSlashShortcut);
        return () => window.removeEventListener('keydown', handleSlashShortcut);
    }, []);

    // Scroll to top button
    useEffect(() => {
        const handleScroll = () => {
            setShowScrollTop(window.scrollY > 400);
        };
        window.addEventListener('scroll', handleScroll);
        return () => window.removeEventListener('scroll', handleScroll);
    }, []);

    useEffect(() => {
        setUsers([]);
        setPage(1);
        setHasMore(true);
        loadUsers(1, true);
    }, [debouncedSearch, skillFilter, skillCategory, sort, availability, location, minRating]);

    useEffect(() => {
        if (page > 1) {
            loadUsers(page, false);
        }
    }, [page]);

    const loadUsers = async (pageNum, reset) => {
        setLoading(true);
        try {
            const params = { page: pageNum, limit: 12 };
            if (debouncedSearch) params.search = debouncedSearch;
            if (skillFilter) params.skill = skillFilter;
            if (sort) params.sort = sort;
            if (availability) params.availability = availability;
            if (location) params.location = location;
            
            const response = await window.apiClient.getUsers(params);
            
            let fetchedUsers = response.users || [];
            console.log('📊 Loaded users from API:', fetchedUsers.length);
            
            setTotalUsers(response.total || fetchedUsers.length);
            if (user) {
                fetchedUsers = fetchedUsers.filter(u => u.id !== user.id);
            }
            
            // Apply client-side filters only if they have values
            let filteredUsers = fetchedUsers;
            
            // Filter by skill category (case-insensitive partial match)
            if (skillCategory && skillCategory !== 'All') {
                const categoryLower = skillCategory.toLowerCase();
                filteredUsers = filteredUsers.filter(u => {
                    const offeredSkills = (u.skills_offered || []).map(s => s.toLowerCase());
                    const wantedSkills = (u.skills_wanted || []).map(s => s.toLowerCase());
                    const allSkills = [...offeredSkills, ...wantedSkills];
                    
                    // Check if any skill contains the category as substring
                    return allSkills.some(skill => skill.includes(categoryLower));
                });
                console.log(`🔍 After category filter (${skillCategory}):`, filteredUsers.length);
            }
            
            // Filter by minimum rating (only if user has rating)
            if (minRating) {
                const minRatingNum = parseFloat(minRating);
                filteredUsers = filteredUsers.filter(u => {
                    // Only filter out if user has a rating AND it's below minimum
                    // If no rating, still show the user
                    return !u.rating || u.rating >= minRatingNum;
                });
                console.log(`⭐ After rating filter (>=${minRating}):`, filteredUsers.length);
            }
            
            console.log('✅ Final filtered users:', filteredUsers.length);
            
            setUsers(prev => reset ? filteredUsers : [...prev, ...filteredUsers]);
            setHasMore(filteredUsers.length === 12);

            // Generate recommendations based on user's wanted skills
            if (reset && user && user.skills_wanted && user.skills_wanted.length > 0) {
                const recs = filteredUsers.filter(u => {
                    const offeredSkills = u.skills_offered || [];
                    return offeredSkills.some(s => user.skills_wanted.includes(s));
                }).slice(0, 4);
                setRecommendedUsers(recs);
                console.log('💡 Recommended users:', recs.length);
            }
        } catch (error) {
            console.error('❌ Failed to load users:', error);
            showToast('Failed to load users', 'error');
        } finally {
            setLoading(false);
        }
    };

    const showToast = (message, type) => {
        setToast({ show: true, message, type });
        setTimeout(() => setToast({ show: false, message: '', type: 'success' }), 3000);
    };

    const handleSendRequest = async (skillOffered, skillRequested, message) => {
        try {
            await window.apiClient.createRequest(requestModal.user.id, skillOffered, skillRequested, message);
            setRequestModal({ open: false, user: null });
            showToast('Skill swap request sent successfully!', 'success');
        } catch (error) {
            const errorMsg = error.message.includes('Conflict') ? 'A pending request already exists for these skills.' : error.message;
            showToast('Failed to send request: ' + errorMsg, 'error');
        }
    };

    const saveRecentlyViewed = (userItem) => {
        const viewed = safeReadArray('recentlyViewed');
        const filtered = viewed.filter(v => v.id !== userItem.id);
        filtered.unshift({ id: userItem.id, first_name: userItem.first_name, profile_image: userItem.profile_image });
        localStorage.setItem('recentlyViewed', JSON.stringify(filtered.slice(0, 10)));
        setRecentlyViewed(filtered.slice(0, 4));
    };

    const handleViewUser = (userItem) => {
        saveRecentlyViewed(userItem);
    };

    const handleQuickView = (userItem) => {
        saveRecentlyViewed(userItem);
        setQuickViewUser(userItem);
    };

    useEffect(() => {
        if (!quickViewUser) return undefined;
        const onKey = (e) => {
            if (e.key === 'Escape') setQuickViewUser(null);
        };
        document.body.style.overflow = 'hidden';
        window.addEventListener('keydown', onKey);
        return () => {
            document.body.style.overflow = '';
            window.removeEventListener('keydown', onKey);
        };
    }, [quickViewUser]);

    const toggleSaveForLater = (userId) => {
        const next = savedForLater.includes(userId) ? savedForLater.filter(id => id !== userId) : [...savedForLater, userId];
        setSavedForLater(next);
        localStorage.setItem('savedForLaterUsers', JSON.stringify(next));
    };

    const calculateMatch = (userItem) => {
        if (!user || !user.skills_wanted || !userItem.skills_offered) return 0;
        const matches = userItem.skills_offered.filter(s => user.skills_wanted.includes(s)).length;
        return Math.min(Math.round((matches / user.skills_wanted.length) * 100), 100);
    };

    const getMutualSkills = (userItem) => {
        if (!user) return 0;
        const mySkills = [...(user.skills_offered || []), ...(user.skills_wanted || [])];
        const theirSkills = [...(userItem.skills_offered || []), ...(userItem.skills_wanted || [])];
        return mySkills.filter(s => theirSkills.includes(s)).length;
    };

    const getRecommendationWhy = (userItem) => {
        if (!user || !user.skills_wanted || !userItem.skills_offered) return [];
        return userItem.skills_offered.filter(s => user.skills_wanted.includes(s)).slice(0, 3);
    };

    const getAvailabilityMeta = (userItem) => {
        const rawAvailability = userItem && userItem.availability !== undefined && userItem.availability !== null
            ? String(userItem.availability)
            : '';
        const value = rawAvailability.toLowerCase();
        if (value.includes('available')) return { label: 'Available', dot: 'bg-green-500', text: 'text-green-300' };
        if (value.includes('busy') || value.includes('weekends') || value.includes('evenings')) return { label: 'Busy', dot: 'bg-yellow-500', text: 'text-yellow-300' };
        return { label: 'Offline', dot: 'bg-slate-500', text: 'text-slate-300' };
    };

    const scrollToResults = () => {
        const el = document.getElementById('discover-results');
        if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    const clearAllFilters = () => {
        setSearch('');
        setSkillFilter('');
        setSkillCategory('');
        setSort('');
        setAvailability('');
        setLocation('');
        setMinRating('');
        scrollToResults();
    };

    const activeFiltersCount = [search, skillFilter, skillCategory, sort, availability, location, minRating].filter(Boolean).length;
    
    const toggleFilterSection = (section) => {
        setFilterSections(prev => ({ ...prev, [section]: !prev[section] }));
    };

    const renderUserCard = (userItem, isLast) => {
        const matchPercent = calculateMatch(userItem);
        const mutualSkills = getMutualSkills(userItem);
        const availabilityMeta = getAvailabilityMeta(userItem);
        const isSaved = savedForLater.includes(userItem.id);
        
        if (viewMode === 'list') {
            return (
                <div ref={isLast ? lastUserElementRef : null} key={userItem.id} onClick={() => handleQuickView(userItem)} className="cursor-pointer group bg-slate-800/40 border border-slate-700/50 hover:border-brand-500/50 rounded-xl shadow-md p-4 transition-all duration-300 hover-lift flex items-center gap-4">
                    <div className="relative">
                        {userItem.profile_image ? (
                            <img src={userItem.profile_image} alt={userItem.first_name} className="w-16 h-16 rounded-full object-cover border-2 border-slate-700 group-hover:border-brand-500 transition-all" />
                        ) : (
                            <div className="w-16 h-16 bg-gradient-to-br from-brand-500 to-brand-700 rounded-full flex items-center justify-center text-white font-bold text-xl border-2 border-slate-700 group-hover:border-brand-500 transition-all">
                                {userItem.first_name ? userItem.first_name[0].toUpperCase() : 'U'}
                            </div>
                        )}
                        <span className={`absolute bottom-0 right-0 w-4 h-4 rounded-full border-2 border-slate-800 ${availabilityMeta.dot}`}></span>
                    </div>
                    <div className="flex-1">
                        <div className="flex items-center gap-2 mb-1">
                            <h3 className="font-semibold text-lg text-white group-hover:text-brand-400 transition-colors">{userItem.first_name || 'Unknown'}</h3>
                            {matchPercent > 0 && (
                                <span className="px-2 py-0.5 bg-brand-500/20 text-brand-300 text-xs rounded-full border border-brand-500/30">{matchPercent}% Match</span>
                            )}
                        </div>
                        <p className="text-slate-400 text-sm flex items-center gap-1 mb-2">
                            <svg className="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fillRule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clipRule="evenodd"></path></svg>
                            {userItem.location || 'Unknown'}
                        </p>
                        <p className={`text-xs mb-2 flex items-center gap-1.5 ${availabilityMeta.text}`}>
                            <span className={`w-2 h-2 rounded-full ${availabilityMeta.dot}`}></span>
                            {availabilityMeta.label}
                        </p>
                        {mutualSkills > 0 && (
                            <p className="text-xs text-brand-300 mb-2">{mutualSkills} skills in common</p>
                        )}
                        <div className="flex flex-wrap gap-1.5">
                            {userItem.skills_offered && userItem.skills_offered.slice(0, 3).map((skill, idx) => (
                                <span key={idx} className="bg-green-500/10 text-green-400 border border-green-500/20 px-2 py-0.5 rounded-full text-xs">{skill}</span>
                            ))}
                        </div>
                    </div>
                    <div className="flex flex-col items-end gap-2">
                        <div className="flex items-center gap-1 text-yellow-400">
                            {[...Array(5)].map((_, i) => (
                                <svg key={i} className={`w-4 h-4 ${i < Math.floor(userItem.rating || 0) ? 'fill-current' : 'fill-slate-600'}`} viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                            ))}
                        </div>
                        <div className="flex gap-2">
                            <button
                                onClick={(e) => { e.stopPropagation(); toggleSaveForLater(userItem.id); }}
                                className={`p-2 rounded-lg border transition-all ${isSaved ? 'bg-red-500/20 border-red-500/40 text-red-400' : 'bg-slate-700/60 border-slate-600 text-slate-300 hover:text-red-400 hover:border-red-500/40'}`}
                                title="Save for later"
                            >
                                {isSaved ? '♥' : '♡'}
                            </button>
                            <button onClick={(e) => { e.stopPropagation(); handleQuickView(userItem); }} className="px-4 py-1.5 bg-slate-700/70 text-slate-200 border border-slate-600 rounded-lg text-sm hover:bg-slate-600 hover:border-slate-500 transition-all">Quick View</button>
                            <button onClick={(e) => { e.stopPropagation(); setRequestModal({ open: true, user: userItem }); }} className="px-5 py-1.5 bg-gradient-to-r from-brand-600 to-purple-600 text-white rounded-lg text-sm font-semibold hover:from-brand-500 hover:to-purple-500 transition-all btn-ripple hover:shadow-lg hover:shadow-brand-500/30">Request Swap</button>
                        </div>
                    </div>
                </div>
            );
        }
        
        return (
            <div ref={isLast ? lastUserElementRef : null} key={userItem.id} onClick={() => handleQuickView(userItem)} className="cursor-pointer group bg-slate-800/40 border border-slate-700/50 hover:border-brand-500/50 rounded-2xl shadow-md p-6 transition-all duration-300 hover-lift flex flex-col h-full relative">
                {matchPercent > 0 && (
                    <div className="absolute top-3 right-3 px-2 py-1 bg-brand-500/20 text-brand-300 text-xs rounded-full border border-brand-500/30 font-semibold">
                        {matchPercent}% Match
                    </div>
                )}
                <div className="flex items-start mb-5">
                    <div className="relative">
                        {userItem.profile_image ? (
                            <img src={userItem.profile_image} alt={userItem.first_name} className="w-14 h-14 rounded-full object-cover border-2 border-slate-700 group-hover:border-brand-500 transition-all duration-300" />
                        ) : (
                            <div className="w-14 h-14 bg-gradient-to-br from-brand-500 to-brand-700 rounded-full flex items-center justify-center text-white font-bold text-xl border-2 border-slate-700 group-hover:border-brand-500 transition-all duration-300 group-hover:scale-110">
                                {userItem.first_name ? userItem.first_name[0].toUpperCase() : 'U'}
                            </div>
                        )}
                        <span className={`absolute bottom-0 right-0 w-3 h-3 rounded-full border-2 border-slate-800 ${availabilityMeta.dot}`}></span>
                    </div>
                    <div className="ml-4 flex-1">
                        <h3 className="font-semibold text-lg text-white group-hover:text-brand-400 transition-colors">{userItem.first_name || 'Unknown'}</h3>
                        <p className="text-slate-400 text-sm flex items-center gap-1">
                            <svg className="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fillRule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clipRule="evenodd"></path></svg>
                            {userItem.location || 'Unknown'}
                        </p>
                        <div className="flex items-center gap-1 mt-1">
                            {userItem.rating && userItem.rating > 0 ? (
                                <>
                                    {[...Array(5)].map((_, i) => (
                                        <svg key={i} className={`w-3 h-3 ${i < Math.floor(userItem.rating) ? 'fill-yellow-400' : 'fill-slate-600'}`} viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                    ))}
                                    <span className="text-xs text-slate-400 ml-1">⭐ {userItem.rating.toFixed(1)} ({userItem.rating_count || 0})</span>
                                </>
                            ) : (
                                <span className="text-xs text-slate-500">No ratings yet</span>
                            )}
                        </div>
                        <div className={`mt-1 text-xs flex items-center gap-1.5 ${availabilityMeta.text}`}>
                            <span className={`w-2 h-2 rounded-full ${availabilityMeta.dot}`}></span>
                            {availabilityMeta.label}
                        </div>
                    </div>
                </div>
                
                {userItem.bio && (
                    <p className="text-slate-300 text-sm mb-4 line-clamp-2">{userItem.bio}</p>
                )}
                
                {mutualSkills > 0 && (
                    <div className="mb-3 text-xs text-brand-400 flex items-center gap-1">
                        <svg className="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/></svg>
                        {mutualSkills} skills in common
                    </div>
                )}
                
                <div className="mb-4 flex-grow">
                    <h4 className="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Offers</h4>
                    <div className="flex flex-wrap gap-1.5">
                        {userItem.skills_offered && userItem.skills_offered.length > 0 ? (
                            userItem.skills_offered.slice(0,3).map((skill, idx) => (
                                <span key={idx} className="bg-green-500/10 text-green-400 border border-green-500/20 px-2 py-0.5 rounded-full text-xs font-medium transition-all duration-200 hover:bg-green-500/20">
                                    {skill}
                                </span>
                            ))
                        ) : <span className="text-slate-500 text-xs italic">No skills added yet</span>}
                    </div>
                </div>
                
                <button
                    onClick={(e) => { e.stopPropagation(); setRequestModal({ open: true, user: userItem }); }}
                    className="w-full mt-auto bg-gradient-to-r from-brand-600 to-purple-600 text-white border-0 py-2.5 rounded-xl font-semibold transition-all duration-300 hover:from-brand-500 hover:to-purple-500 hover:shadow-lg hover:shadow-brand-500/30 hover:scale-[1.02] btn-ripple"
                >
                    Request Swap
                </button>
                <div className="mt-3 grid grid-cols-3 gap-2">
                    <button
                        onClick={(e) => { e.stopPropagation(); toggleSaveForLater(userItem.id); }}
                        className={`col-span-1 py-2 rounded-lg border transition-all text-sm ${isSaved ? 'bg-red-500/20 border-red-500/40 text-red-400' : 'bg-slate-700/50 border-slate-600 text-slate-300 hover:text-red-400 hover:border-red-500/40'}`}
                        title="Save for later"
                    >
                        {isSaved ? '♥' : '♡'}
                    </button>
                    <button
                        onClick={(e) => { e.stopPropagation(); handleQuickView(userItem); }}
                        className="col-span-2 py-2 rounded-lg border border-slate-600 bg-slate-700/50 text-slate-200 hover:bg-slate-600 hover:border-slate-500 transition-all text-sm"
                    >
                        Quick View
                    </button>
                </div>
            </div>
        );
    };

    return (
        <div className="min-h-screen bg-slate-950 animate-fadeIn">
            {/* Toast Notifications */}
            {toast.show && (
                <div className={`fixed top-20 right-4 p-4 rounded-lg shadow-2xl z-50 animate-toastIn flex items-center gap-3 ${toast.type === 'error' ? 'bg-red-500/90 text-white border border-red-400' : 'bg-green-500/90 text-white border border-green-400'}`}>
                    {toast.type === 'error' ? (
                        <svg className="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clipRule="evenodd"/></svg>
                    ) : (
                        <svg className="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"/></svg>
                    )}
                    <span className="font-medium">{toast.message}</span>
                </div>
            )}

            {/* Hero Banner with Search */}
            <div className="bg-gradient-to-r from-brand-600/20 via-purple-600/20 to-brand-600/20 border-b border-slate-800">
                <div className="container mx-auto px-4 py-8">
                    <h1 className="text-4xl font-bold mb-4 text-white">Discover Skills & People</h1>
                    <p className="text-slate-300 mb-6">Find the perfect skill swap partner from our community</p>
                    
                    {/* Quick Search Bar */}
                    <div className="max-w-2xl">
                        <div className="relative">
                            <input 
                                type="text" 
                                placeholder="Search by name, location, or skill..." 
                                className="w-full pl-12 pr-4 py-4 rounded-full bg-slate-800/60 border border-slate-700 text-slate-100 placeholder-slate-400 focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all text-lg"
                                value={search}
                                ref={searchInputRef}
                                onChange={e => { setSearch(e.target.value); scrollToResults(); }}
                            />
                            <svg className="absolute left-4 top-1/2 -translate-y-1/2 w-6 h-6 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                        </div>
                    </div>
                    <p className="text-xs text-slate-400 mt-3">Press <span className="px-1.5 py-0.5 rounded bg-slate-800 text-slate-300">/</span> to search</p>

                    {/* Popular Skills Pills */}
                    <div className="mt-4 flex flex-wrap gap-2">
                        <span className="text-sm text-slate-400">Popular:</span>
                        {popularSkills.map(skill => (
                            <button
                                key={skill}
                                onClick={() => { setSkillFilter(skill); scrollToResults(); }}
                                className="px-3 py-1 bg-slate-800/60 hover:bg-brand-600 text-slate-300 hover:text-white rounded-full text-sm transition-all border border-slate-700 hover:border-brand-500"
                            >
                                {skill}
                            </button>
                        ))}
                    </div>
                </div>
            </div>

            <div className="container mx-auto px-4 py-6">
                {/* Active Filters & Controls */}
                <div className="flex flex-wrap items-center justify-between gap-4 mb-6">
                    <div className="flex flex-wrap items-center gap-2">
                        {activeFiltersCount > 0 && (
                            <>
                                <span className="text-sm text-slate-400">Active filters:</span>
                                {search && <span className="px-3 py-1 bg-slate-800 text-slate-300 rounded-full text-sm flex items-center gap-2">Search: {search} <button onClick={() => setSearch('')} className="hover:text-white">×</button></span>}
                                {skillFilter && <span className="px-3 py-1 bg-slate-800 text-slate-300 rounded-full text-sm flex items-center gap-2">{skillFilter} <button onClick={() => setSkillFilter('')} className="hover:text-white">×</button></span>}
                                {skillCategory && skillCategory !== 'All' && <span className="px-3 py-1 bg-slate-800 text-slate-300 rounded-full text-sm flex items-center gap-2">{skillCategory} <button onClick={() => setSkillCategory('')} className="hover:text-white">×</button></span>}
                                {location && <span className="px-3 py-1 bg-slate-800 text-slate-300 rounded-full text-sm flex items-center gap-2">{location} <button onClick={() => setLocation('')} className="hover:text-white">×</button></span>}
                                {availability && <span className="px-3 py-1 bg-slate-800 text-slate-300 rounded-full text-sm flex items-center gap-2">{availability} <button onClick={() => setAvailability('')} className="hover:text-white">×</button></span>}
                                <button onClick={clearAllFilters} className="px-3 py-1 bg-red-500/20 text-red-400 hover:bg-red-500 hover:text-white rounded-full text-sm transition-all border border-red-500/30">Clear All</button>
                            </>
                        )}
                    </div>
                    
                    <div className="flex items-center gap-3">
                        <span className="text-sm text-slate-400">Showing {users.length} of {totalUsers || users.length} users</span>
                        <div className="flex gap-1 bg-slate-800 rounded-lg p-1">
                            <button onClick={() => setViewMode('grid')} className={`p-2 rounded transition-all ${viewMode === 'grid' ? 'bg-brand-600 text-white' : 'text-slate-400 hover:text-white'}`}>
                                <svg className="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V5zM11 13a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                            </button>
                            <button onClick={() => setViewMode('list')} className={`p-2 rounded transition-all ${viewMode === 'list' ? 'bg-brand-600 text-white' : 'text-slate-400 hover:text-white'}`}>
                                <svg className="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fillRule="evenodd" d="M3 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clipRule="evenodd"/></svg>
                            </button>
                        </div>
                        <div className="relative">
                            <svg className="w-4 h-4 text-slate-400 absolute left-3 top-1/2 -translate-y-1/2" fill="currentColor" viewBox="0 0 20 20"><path d="M3 6h14M6 10h8m-10 4h12" /></svg>
                            <select
                                className="pl-8 pr-3 py-2 rounded-lg bg-slate-800 border border-slate-700 text-slate-200 text-sm focus:ring-2 focus:ring-brand-500"
                                value={sort}
                                onChange={(e) => { setSort(e.target.value); scrollToResults(); }}
                            >
                                <option value="">Sort: Relevance</option>
                                <option value="highest_rated">Highest Rated</option>
                                <option value="online_now">Recently Active</option>
                                <option value="new_members">New Members</option>
                            </select>
                        </div>
                        <button onClick={() => setShowFilters(!showFilters)} className="md:hidden px-4 py-2 bg-slate-800 text-slate-300 rounded-lg hover:bg-slate-700 transition-all flex items-center gap-2">
                            <svg className="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fillRule="evenodd" d="M3 3a1 1 0 011-1h12a1 1 0 011 1v3a1 1 0 01-.293.707L12 11.414V15a1 1 0 01-.293.707l-2 2A1 1 0 018 17v-5.586L3.293 6.707A1 1 0 013 6V3z" clipRule="evenodd"/></svg>
                            Filters
                        </button>
                    </div>
                </div>

                {/* Two Column Layout */}
                <div id="discover-results" className="flex gap-6 scroll-mt-24">
                    {/* Left Sidebar - Filters */}
                    <div className={`${showFilters ? 'block' : 'hidden'} md:block w-full md:w-64 flex-shrink-0`}>
                        <div className="bg-slate-800/40 border border-slate-700 rounded-xl p-4 sticky top-4 space-y-4">
                            <h3 className="font-semibold text-white mb-4 flex items-center gap-2">
                                <svg className="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fillRule="evenodd" d="M3 3a1 1 0 011-1h12a1 1 0 011 1v3a1 1 0 01-.293.707L12 11.414V15a1 1 0 01-.293.707l-2 2A1 1 0 018 17v-5.586L3.293 6.707A1 1 0 013 6V3z" clipRule="evenodd"/></svg>
                                Filters
                            </h3>
                            
                            <div className="border-t border-slate-700 pt-3">
                                <button onClick={() => toggleFilterSection('skills')} className="w-full flex items-center justify-between text-sm font-medium text-slate-200 mb-3">
                                    <span>Skills</span><span>{filterSections.skills ? '−' : '+'}</span>
                                </button>
                                {filterSections.skills && (
                                    <div className="space-y-3">
                                        <div>
                                            <label className="block text-sm font-medium text-slate-300 mb-2">Category</label>
                                            <select className="w-full px-3 py-2 rounded-lg bg-slate-900/70 border border-slate-700 text-slate-100 text-sm focus:ring-2 focus:ring-brand-500 transition-all" value={skillCategory} onChange={e => { setSkillCategory(e.target.value); scrollToResults(); }}>
                                                {skillCategories.map(cat => (
                                                    <option key={cat} value={cat}>{cat}</option>
                                                ))}
                                            </select>
                                        </div>
                                        <div>
                                            <label className="block text-sm font-medium text-slate-300 mb-2">Skill Search</label>
                                            <input type="text" placeholder="e.g. JavaScript" className="w-full px-3 py-2 rounded-lg bg-slate-900/70 border border-slate-700 text-slate-100 text-sm focus:ring-2 focus:ring-brand-500 transition-all" value={skillFilter} onChange={e => { setSkillFilter(e.target.value); scrollToResults(); }} />
                                        </div>
                                    </div>
                                )}
                            </div>

                            <div className="border-t border-slate-700 pt-3">
                                <button onClick={() => toggleFilterSection('location')} className="w-full flex items-center justify-between text-sm font-medium text-slate-200 mb-3">
                                    <span>Location</span><span>{filterSections.location ? '−' : '+'}</span>
                                </button>
                                {filterSections.location && (
                                    <input type="text" placeholder="City or country" className="w-full px-3 py-2 rounded-lg bg-slate-900/70 border border-slate-700 text-slate-100 text-sm focus:ring-2 focus:ring-brand-500 transition-all" value={location} onChange={e => { setLocation(e.target.value); scrollToResults(); }} />
                                )}
                            </div>

                            <div className="border-t border-slate-700 pt-3">
                                <button onClick={() => toggleFilterSection('availability')} className="w-full flex items-center justify-between text-sm font-medium text-slate-200 mb-3">
                                    <span>Availability</span><span>{filterSections.availability ? '−' : '+'}</span>
                                </button>
                                {filterSections.availability && (
                                    <select className="w-full px-3 py-2 rounded-lg bg-slate-900/70 border border-slate-700 text-slate-100 text-sm focus:ring-2 focus:ring-brand-500 transition-all" value={availability} onChange={e => { setAvailability(e.target.value); scrollToResults(); }}>
                                        <option value="">Any</option>
                                        <option value="Available">Available</option>
                                        <option value="Busy">Busy</option>
                                        <option value="Offline">Offline</option>
                                    </select>
                                )}
                            </div>

                            <div className="border-t border-slate-700 pt-3">
                                <button onClick={() => toggleFilterSection('rating')} className="w-full flex items-center justify-between text-sm font-medium text-slate-200 mb-3">
                                    <span>Rating</span><span>{filterSections.rating ? '−' : '+'}</span>
                                </button>
                                {filterSections.rating && (
                                    <select className="w-full px-3 py-2 rounded-lg bg-slate-900/70 border border-slate-700 text-slate-100 text-sm focus:ring-2 focus:ring-brand-500 transition-all" value={minRating} onChange={e => { setMinRating(e.target.value); scrollToResults(); }}>
                                        <option value="">Any</option>
                                        <option value="4">4+ Stars</option>
                                        <option value="3">3+ Stars</option>
                                        <option value="2">2+ Stars</option>
                                    </select>
                                )}
                            </div>
                        </div>
                    </div>

                    {/* Right Content Area */}
                    <div className="flex-1">
                        {/* Smart Recommendations */}
                        {recommendedUsers.length > 0 && !search && !skillFilter && (
                            <div className="mb-8 bg-gradient-to-r from-brand-600/10 via-purple-600/10 to-brand-600/10 border border-brand-500/30 rounded-2xl p-6">
                                <div className="flex items-center justify-between mb-4">
                                    <h2 className="text-xl font-bold text-brand-300 flex items-center gap-2">
                                        ✨ Recommended for You
                                        <span className="text-xs bg-brand-500/20 text-brand-300 px-2 py-1 rounded-full">Based on your skills</span>
                                    </h2>
                                </div>
                                <div className="flex gap-4 overflow-x-auto pb-2">
                                    {recommendedUsers.map((u) => {
                                        const whySkills = getRecommendationWhy(u);
                                        return (
                                            <div key={`rec-${u.id}`} className="min-w-[280px] max-w-[320px] relative group">
                                                <div className="absolute right-3 top-3 z-10">
                                                    <div className="relative">
                                                        <span className="text-xs px-2 py-1 rounded-full bg-slate-900/80 border border-slate-700 text-slate-300 cursor-help">Why recommended?</span>
                                                        <div className="pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity absolute right-0 mt-2 w-56 p-2 rounded-lg bg-slate-900 border border-slate-700 text-xs text-slate-300">
                                                            {whySkills.length > 0 ? `Matches: ${whySkills.join(', ')}` : 'Strong profile overlap with your interests.'}
                                                        </div>
                                                    </div>
                                                </div>
                                                {renderUserCard(u, false)}
                                            </div>
                                        );
                                    })}
                                </div>
                                <div className="mt-4">
                                    <button onClick={() => window.scrollTo({ top: document.getElementById('discover-results')?.offsetTop || 0, behavior: 'smooth' })} className="px-4 py-2 rounded-lg bg-brand-600 text-white hover:bg-brand-500 transition-all text-sm">See More Recommendations</button>
                                </div>
                            </div>
                        )}

                        {/* All Users */}
                        <div className="border-t border-slate-800 pt-6">
                            <h2 className="text-xl font-bold mb-4 text-white">All Users</h2>
                            
                            {users.length === 0 && !loading ? (
                                <div className="text-center py-16 bg-slate-800/40 border border-slate-700/50 rounded-2xl">
                                    <div className="text-6xl mb-4">🧭</div>
                                    <h3 className="text-xl font-bold text-white mb-2">
                                        {activeFiltersCount > 0 ? 'No Exact Matches Found' : 'No Users Available'}
                                    </h3>
                                    <p className="text-slate-400 mb-4 max-w-md mx-auto">
                                        {activeFiltersCount > 0 
                                            ? 'Try adjusting your filters or search terms to find more people' 
                                            : 'Check back later for new users to connect with'}
                                    </p>
                                    {activeFiltersCount > 0 && (
                                        <div className="space-y-3">
                                            <button onClick={clearAllFilters} className="px-6 py-2.5 bg-brand-600 text-white rounded-xl hover:bg-brand-500 transition-all btn-ripple font-medium shadow-lg shadow-brand-500/30">
                                                Clear All Filters
                                            </button>
                                            <p className="text-xs text-slate-500">
                                                Active filters: {activeFiltersCount}
                                            </p>
                                        </div>
                                    )}
                                </div>
                            ) : (
                                <div className={viewMode === 'grid' ? 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6' : 'space-y-4'}>
                                    {users.map((userItem, index) => renderUserCard(userItem, index === users.length - 1))}
                                    {loading && Array.from({ length: 4 }).map((_, i) => <UserCardSkeleton key={`skel-${i}`} />)}
                                </div>
                            )}

                            {loading && users.length > 0 && (
                                <div className="text-center py-8 text-slate-400">Loading more...</div>
                            )}
                        </div>

                        {/* Recently Viewed */}
                        {recentlyViewed.length > 0 && (
                            <div className="mt-12 pt-8 border-t border-slate-800">
                                <h2 className="text-lg font-semibold text-slate-300 mb-4">Recently Viewed</h2>
                                <div className="flex gap-4 overflow-x-auto pb-2">
                                    {recentlyViewed.map(rv => (
                                        <div key={rv.id} className="flex-shrink-0 w-32 text-center">
                                            <div className="w-16 h-16 mx-auto mb-2 rounded-full bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center text-white font-bold text-xl">
                                                {rv.first_name?.[0] || 'U'}
                                            </div>
                                            <p className="text-sm text-slate-300 truncate">{rv.first_name}</p>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        )}
                    </div>
                </div>
            </div>

            {/* Scroll to Top Button */}
            {showScrollTop && (
                <button
                    onClick={() => window.scrollTo({ top: 0, behavior: 'smooth' })}
                    className="fixed bottom-8 right-8 w-12 h-12 bg-brand-600 text-white rounded-full shadow-lg hover:bg-brand-500 transition-all hover:scale-110 flex items-center justify-center z-40 animate-fadeIn"
                >
                    <svg className="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M5 10l7-7m0 0l7 7m-7-7v18" /></svg>
                </button>
            )}
            
            <SwapRequestModal 
                isOpen={requestModal.open} 
                onClose={() => setRequestModal({ open: false, user: null })} 
                userItem={requestModal.user} 
                onSubmit={handleSendRequest} 
            />
            {quickViewUser && (
                <ModalPortal>
                  <div className="modal-overlay">
                    <div className="modal-backdrop bg-black/60 backdrop-blur-sm animate-fadeIn" onClick={() => setQuickViewUser(null)}></div>
                    <div className="modal-content bg-slate-900 border border-slate-700 rounded-2xl shadow-2xl animate-scaleIn" style={{ width: '90%', maxWidth: '32rem' }} onClick={(e) => e.stopPropagation()}>
                        <div className="sticky top-0 bg-slate-900 border-b border-slate-700 px-6 py-4 flex items-center justify-between z-10">
                            <h3 className="text-xl font-semibold text-white">User Profile</h3>
                            <button onClick={() => setQuickViewUser(null)} className="text-slate-400 hover:text-white text-2xl leading-none transition-colors">×</button>
                        </div>
                        
                        <div className="p-6 space-y-6">
                            {/* User Header */}
                            <div className="flex items-start gap-4">
                                <div className="relative">
                                    {quickViewUser.profile_image ? (
                                        <img src={quickViewUser.profile_image} alt={quickViewUser.first_name} className="w-20 h-20 rounded-full object-cover border-2 border-slate-700" />
                                    ) : (
                                        <div className="w-20 h-20 rounded-full bg-gradient-to-br from-brand-500 to-purple-600 flex items-center justify-center text-white font-bold text-2xl border-2 border-slate-700">
                                            {quickViewUser.first_name?.[0]?.toUpperCase() || 'U'}
                                        </div>
                                    )}
                                    <span className={`absolute bottom-0 right-0 w-5 h-5 rounded-full border-2 border-slate-900 ${getAvailabilityMeta(quickViewUser).dot}`}></span>
                                </div>
                                <div className="flex-1">
                                    <h4 className="text-xl font-bold text-white mb-1">{quickViewUser.first_name || 'Unknown User'}</h4>
                                    <p className="text-slate-400 text-sm flex items-center gap-1 mb-2">
                                        <svg className="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fillRule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clipRule="evenodd"></path></svg>
                                        {quickViewUser.location || 'Location not specified'}
                                    </p>
                                    <div className={`text-sm flex items-center gap-2 ${getAvailabilityMeta(quickViewUser).text}`}>
                                        <span className={`w-2 h-2 rounded-full ${getAvailabilityMeta(quickViewUser).dot}`}></span>
                                        {getAvailabilityMeta(quickViewUser).label}
                                    </div>
                                    <div className="flex items-center gap-1 mt-2">
                                        {quickViewUser.rating && quickViewUser.rating > 0 ? (
                                            <>
                                                {[...Array(5)].map((_, i) => (
                                                    <svg key={i} className={`w-4 h-4 ${i < Math.floor(quickViewUser.rating) ? 'fill-yellow-400' : 'fill-slate-600'}`} viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                                ))}
                                                <span className="text-sm text-slate-400 ml-1">⭐ {quickViewUser.rating.toFixed(1)} ({quickViewUser.rating_count || 0})</span>
                                            </>
                                        ) : (
                                            <span className="text-sm text-slate-500">No ratings yet</span>
                                        )}
                                    </div>
                                </div>
                            </div>

                            {/* Bio Section */}
                            <div>
                                <h5 className="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-2">Bio</h5>
                                {quickViewUser.bio ? (
                                    <p className="text-slate-300 text-sm bg-slate-800/50 p-4 rounded-lg border border-slate-700/50 leading-relaxed">{quickViewUser.bio}</p>
                                ) : (
                                    <p className="text-slate-500 text-sm italic bg-slate-800/30 p-4 rounded-lg border border-slate-700/30">No bio available</p>
                                )}
                            </div>

                            {/* Skills Offered */}
                            <div>
                                <h5 className="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-3">Skills Offered</h5>
                                <div className="flex flex-wrap gap-2">
                                    {quickViewUser.skills_offered && quickViewUser.skills_offered.length > 0 ? (
                                        quickViewUser.skills_offered.map((s, i) => (
                                            <span key={`qv-offered-${i}`} className="px-3 py-1.5 rounded-full text-sm bg-green-500/10 border border-green-500/30 text-green-300 font-medium">{s}</span>
                                        ))
                                    ) : (
                                        <span className="text-slate-500 text-sm italic">No skills added yet</span>
                                    )}
                                </div>
                            </div>

                            {/* Skills Wanted */}
                            {quickViewUser.skills_wanted && quickViewUser.skills_wanted.length > 0 && (
                                <div>
                                    <h5 className="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-3">Skills Wanted</h5>
                                    <div className="flex flex-wrap gap-2">
                                        {quickViewUser.skills_wanted.map((s, i) => (
                                            <span key={`qv-wanted-${i}`} className="px-3 py-1.5 rounded-full text-sm bg-brand-500/10 border border-brand-500/30 text-brand-300 font-medium">{s}</span>
                                        ))}
                                    </div>
                                </div>
                            )}

                            {/* Action Buttons */}
                            <div className="grid grid-cols-2 gap-3 pt-4 border-t border-slate-700">
                                <button onClick={() => { handleViewUser(quickViewUser); setQuickViewUser(null); }} className="w-full py-3 rounded-xl border border-slate-600 bg-slate-800 text-slate-200 hover:bg-slate-700 hover:border-slate-500 transition-all font-medium">Close</button>
                                <button onClick={() => { setQuickViewUser(null); setRequestModal({ open: true, user: quickViewUser }); }} className="w-full py-3 rounded-xl bg-gradient-to-r from-brand-600 to-purple-600 text-white hover:from-brand-500 hover:to-purple-500 transition-all font-semibold hover:shadow-lg hover:shadow-brand-500/30">Request Swap</button>
                            </div>
                        </div>
                    </div>
                  </div>
                </ModalPortal>
            )}
        </div>
    );
};

// Review Modal
const ReviewModal = ({ isOpen, onClose, partnerName, onSubmit }) => {
    const [rating, setRating] = useState(5);
    const [text, setText] = useState('');

    useEffect(() => {
        if (isOpen) {
            document.body.style.overflow = 'hidden';
        } else {
            document.body.style.overflow = 'auto';
        }
        return () => {
            document.body.style.overflow = 'auto';
        };
    }, [isOpen]);

    useEffect(() => {
        if (!isOpen) return;
        const handleEsc = (e) => {
            if (e.key === 'Escape') onClose();
        };
        window.addEventListener('keydown', handleEsc);
        return () => window.removeEventListener('keydown', handleEsc);
    }, [isOpen, onClose]);

    if (!isOpen) return null;

    return (
        <ModalPortal>
          <div className="modal-overlay">
            <div className="modal-backdrop bg-black/60 backdrop-blur-sm animate-fadeIn" onClick={onClose}></div>
            <div className="modal-content bg-slate-800 border border-slate-700 rounded-2xl shadow-2xl animate-scaleIn overflow-hidden" style={{ width: '100%', maxWidth: '28rem' }}>
                <div className="bg-gradient-to-r from-brand-600 to-purple-600 px-6 py-4">
                    <h3 className="text-xl font-semibold text-white">Rate your swap with {partnerName}</h3>
                </div>
                <div className="p-6 space-y-5">
                    <div>
                        <label className="block text-sm font-semibold text-slate-300 mb-3">Rating</label>
                        <div className="flex gap-2 justify-center">
                            {[1, 2, 3, 4, 5].map(star => (
                                <button key={star} type="button" onClick={() => setRating(star)} className={`text-3xl ${rating >= star ? 'text-yellow-400' : 'text-slate-600'} hover:scale-110 transition-transform`}>
                                    ⭐
                                </button>
                            ))}
                        </div>
                    </div>
                    <div>
                        <label className="block text-sm font-semibold text-slate-300 mb-2">Review (optional)</label>
                        <textarea className="w-full px-4 py-3 rounded-xl bg-slate-900/70 border border-slate-700 text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all resize-none"
                                  rows="3" value={text} onChange={(e) => setText(e.target.value)} placeholder="How was your experience?"></textarea>
                    </div>
                    <div className="flex gap-3 pt-2">
                        <button onClick={onClose} className="flex-1 px-4 py-3 rounded-xl bg-slate-700 text-slate-300 hover:bg-slate-600 transition-all duration-200 font-medium btn-ripple">Skip</button>
                        <button onClick={() => onSubmit(rating, text)}
                                className="flex-1 px-4 py-3 rounded-xl bg-gradient-to-r from-brand-600 to-purple-600 text-white hover:from-brand-500 hover:to-purple-500 transition-all duration-200 hover:shadow-lg hover:shadow-brand-500/30 font-semibold btn-ripple">Submit Review</button>
                    </div>
                </div>
            </div>
          </div>
        </ModalPortal>
    );
};



// Skeleton Loader for Requests
const RequestSkeleton = () => (
    <div className="bg-slate-800/40 border border-slate-700/50 rounded-2xl shadow-md p-6">
        <div className="flex gap-4 mb-6">
            <div className="w-12 h-12 rounded-full animate-shimmer"></div>
            <div className="flex-1 space-y-2 py-1">
                <div className="h-4 animate-shimmer rounded w-32"></div>
                <div className="h-3 animate-shimmer rounded w-48"></div>
            </div>
            <div className="h-6 animate-shimmer rounded w-20"></div>
        </div>
        <div className="grid md:grid-cols-2 gap-4 mb-6">
            <div className="h-12 animate-shimmer rounded-xl"></div>
            <div className="h-12 animate-shimmer rounded-xl"></div>
        </div>
        <div className="flex gap-3">
            <div className="h-10 animate-shimmer rounded-xl w-32"></div>
            <div className="h-10 animate-shimmer rounded-xl w-32"></div>
        </div>
    </div>
);

// Requests Page Component
const RequestsPage = () => {
    const [requests, setRequests] = useState([]);
    const [activeTab, setActiveTab] = useState('received');
    const [loading, setLoading] = useState(false);
    const [reviewModal, setReviewModal] = useState({ open: false, request: null });
    const { user } = useAuth();

    useEffect(() => {
        loadRequests();
    }, [activeTab]);

    const loadRequests = async () => {
        setLoading(true);
        try {
            const response = await window.apiClient.getRequests({ type: activeTab });
            setRequests(response.requests || []);
        } catch (error) {
            console.error('Failed to load requests:', error);
        } finally {
            setLoading(false);
        }
    };

    const updateRequestStatus = async (id, action) => {
        try {
            if (action === 'accept') {
                await window.apiClient.acceptRequest(id);
            } else if (action === 'reject') {
                await window.apiClient.rejectRequest(id);
            } else if (action === 'complete') {
                await window.apiClient.completeRequest(id);
            } else if (action === 'delete') {
                await window.apiClient.deleteRequest(id);
            }
            loadRequests();
        } catch (error) {
            alert('Failed to update request: ' + error.message);
        }
    };

    const handleUpdateMilestone = async (id, milestone) => {
        try {
            await window.apiClient.updateMilestone(id, milestone);
            loadRequests();
        } catch (e) {
            alert('Failed to update milestone: ' + e.message);
        }
    };

    const handleReviewSubmit = async (rating, text) => {
        try {
            const req = reviewModal.request;
            const partnerId = activeTab === 'received' ? req.sender.id : req.receiver.id;
            await window.apiClient.addReview(partnerId, rating, text);
            setReviewModal({ open: false, request: null });
        } catch (e) {
            alert('Failed to submit review: ' + e.message);
        }
    };

    if (loading && requests.length === 0) return (
        <div className="container mx-auto px-4 py-8 text-slate-100 max-w-4xl">
            <h1 className="text-3xl font-bold mb-8 text-white">My Swaps Workspace</h1>
            <div className="space-y-4">
                <RequestSkeleton />
                <RequestSkeleton />
                <RequestSkeleton />
            </div>
        </div>
    );

    return (
        <div className="container mx-auto px-4 py-8 text-slate-100 max-w-4xl animate-fadeIn">
            <h1 className="text-3xl font-bold mb-8 text-white">My Swaps Workspace</h1>
            
            <div className="mb-6 flex space-x-4 border-b border-slate-800">
                <button
                    onClick={() => setActiveTab('received')}
                    className={`px-6 py-3 font-semibold text-sm transition-all duration-300 border-b-2 ${activeTab === 'received' ? 'border-brand-500 text-white bg-brand-600/20' : 'border-transparent text-slate-400 hover:text-slate-200'}`}
                >
                    Received Swaps
                </button>
                <button
                    onClick={() => setActiveTab('sent')}
                    className={`px-6 py-3 font-semibold text-sm transition-all duration-300 border-b-2 ${activeTab === 'sent' ? 'border-brand-500 text-white bg-brand-600/20' : 'border-transparent text-slate-400 hover:text-slate-200'}`}
                >
                    Sent Swaps
                </button>
            </div>

            {requests.length === 0 && !loading && (
                <EmptyState icon="📭" title={`No ${activeTab} swaps`} description="You haven't received or sent any swap requests yet." />
            )}

            <div className="space-y-4">
                {requests.map((request) => {
                    const isAccepted = request.status === 'accepted';
                    const isCompleted = request.status === 'completed';
                    const partner = activeTab === 'received' ? request.sender : request.receiver;

                    return (
                        <div key={request.id} className="bg-slate-800/60 border border-slate-700 rounded-2xl shadow-md p-6 hover:border-brand-500/50 hover:shadow-xl hover:shadow-brand-500/10 transition-all duration-300 hover:scale-[1.01] animate-fadeIn">
                            <div className="flex flex-col md:flex-row md:justify-between md:items-start gap-4 mb-6">
                                <div className="flex items-center gap-4">
                                    <div className="w-12 h-12 rounded-full bg-slate-700 flex items-center justify-center text-xl font-bold border-2 border-slate-600">
                                        {partner.first_name ? partner.first_name[0].toUpperCase() : 'U'}
                                    </div>
                                    <div>
                                        <h3 className="font-semibold text-lg text-white">
                                            {partner.first_name}
                                        </h3>
                                        <p className="text-slate-400 text-sm">{partner.email}</p>
                                    </div>
                                </div>
                                <div className="flex flex-col items-end">
                                    <span className={`px-3 py-1 rounded-full text-xs font-medium border ${
                                        request.status === 'pending' ? 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20' :
                                        request.status === 'accepted' ? 'bg-green-500/10 text-green-400 border-green-500/20' :
                                        request.status === 'rejected' ? 'bg-red-500/10 text-red-400 border-red-500/20' :
                                        'bg-brand-500/10 text-brand-400 border-brand-500/20'
                                    }`}>
                                        {request.status.charAt(0).toUpperCase() + request.status.slice(1)}
                                    </span>
                                    <span className="text-slate-500 text-xs mt-2">
                                        {new Date(request.created_at).toLocaleDateString()}
                                    </span>
                                </div>
                            </div>
                            
                            <div className="bg-slate-900/50 rounded-xl p-4 mb-6 border border-slate-700/50">
                                <div className="flex items-center justify-center gap-3 text-center">
                                    <div className="flex-1">
                                        <span className="text-xs text-slate-500 uppercase tracking-wider font-semibold block mb-2">You Offer</span>
                                        <span className="text-brand-400 font-semibold text-lg">{activeTab === 'received' ? request.skill_requested : request.skill_offered}</span>
                                    </div>
                                    <div className="text-2xl text-slate-600">→</div>
                                    <div className="flex-1">
                                        <span className="text-xs text-slate-500 uppercase tracking-wider font-semibold block mb-2">You Want</span>
                                        <span className="text-purple-400 font-semibold text-lg">{activeTab === 'received' ? request.skill_offered : request.skill_requested}</span>
                                    </div>
                                </div>
                                {request.message && (
                                    <div className="mt-4 pt-4 border-t border-slate-700/50">
                                        <span className="text-xs text-slate-500 uppercase tracking-wider font-semibold block mb-2">Message</span>
                                        <p className="text-slate-300 text-sm bg-slate-800 p-3 rounded-lg border border-slate-700/50">"{request.message}"</p>
                                    </div>
                                )}
                            </div>

                            {/* Milestone Tracker for Accepted Swaps */}
                            {isAccepted && (
                                <div className="mb-6 bg-slate-900/30 p-4 rounded-xl border border-slate-700/50">
                                    <div className="flex justify-between items-center mb-2">
                                        <h4 className="text-sm font-semibold text-slate-300">Milestone Progress</h4>
                                        <select 
                                            value={request.milestone || ''} 
                                            onChange={(e) => handleUpdateMilestone(request.id, e.target.value)}
                                            className="bg-slate-800 border border-slate-600 text-xs rounded-lg px-2 py-1 focus:outline-none focus:border-brand-500 text-slate-200"
                                        >
                                            <option value="">Just Started</option>
                                            <option value="Intro Call Scheduled">Intro Call Scheduled</option>
                                            <option value="First Lesson Complete">First Lesson Complete</option>
                                            <option value="Midway">Midway Through</option>
                                            <option value="Final Review">Final Review</option>
                                        </select>
                                    </div>
                                    <div className="h-2 bg-slate-700 rounded-full overflow-hidden">
                                        <div className="h-full bg-brand-500 transition-all duration-500" 
                                             style={{ width: 
                                                request.milestone === 'Final Review' ? '100%' :
                                                request.milestone === 'Midway' ? '75%' :
                                                request.milestone === 'First Lesson Complete' ? '50%' :
                                                request.milestone === 'Intro Call Scheduled' ? '25%' : '5%'
                                             }}>
                                        </div>
                                    </div>
                                </div>
                            )}
                            
                            <div className="flex flex-wrap gap-3">
                                {activeTab === 'received' && request.status === 'pending' && (
                                    <>
                                        <button onClick={() => updateRequestStatus(request.id, 'accept')} className="bg-green-600/20 text-green-400 border border-green-500/30 px-6 py-2 rounded-xl hover:bg-green-600 hover:text-white transition-all duration-300 font-medium text-sm hover:shadow-lg btn-ripple">
                                            Accept Request
                                        </button>
                                        <button onClick={() => updateRequestStatus(request.id, 'reject')} className="bg-red-600/20 text-red-400 border border-red-500/30 px-6 py-2 rounded-xl hover:bg-red-600 hover:text-white transition-all duration-300 font-medium text-sm hover:shadow-lg btn-ripple">
                                            Reject
                                        </button>
                                    </>
                                )}
                                {isAccepted && (
                                    <>
                                        <button onClick={() => window.location.hash = `#messages?request=${request.id}`} className="bg-slate-700 text-white px-6 py-2 rounded-xl hover:bg-slate-600 transition-all duration-300 font-medium text-sm shadow-md flex items-center gap-2 hover:shadow-lg btn-ripple">
                                            💬 Chat
                                        </button>
                                        {activeTab === 'received' && (
                                            <button onClick={() => { updateRequestStatus(request.id, 'complete'); setReviewModal({ open: true, request }); }} className="bg-brand-600 text-white px-6 py-2 rounded-xl hover:bg-brand-500 transition-all duration-300 font-medium text-sm shadow-md shadow-brand-500/20 hover:shadow-lg hover:shadow-brand-500/30 btn-ripple">
                                                Mark as Completed
                                            </button>
                                        )}
                                    </>
                                )}
                                {activeTab === 'sent' && request.status === 'pending' && (
                                    <button onClick={() => updateRequestStatus(request.id, 'delete')} className="bg-red-600/10 text-red-400 border border-red-500/30 px-6 py-2 rounded-xl hover:bg-red-600 hover:text-white hover:border-red-500 transition-all duration-300 font-medium text-sm hover:shadow-lg btn-ripple flex items-center gap-2">
                                        ❌ Cancel Request
                                    </button>
                                )}
                            </div>
                        </div>
                    );
                })}
            </div>
            
            <ReviewModal 
                isOpen={reviewModal.open} 
                onClose={() => setReviewModal({ open: false, request: null })} 
                partnerName={reviewModal.request ? (activeTab === 'received' ? reviewModal.request.sender.first_name : reviewModal.request.receiver.first_name) : ''}
                onSubmit={handleReviewSubmit}
            />
        </div>
    );
};

// Profile Page Component
const ProfilePage = () => {
    const [profile, setProfile] = useState(null);
    const [editing, setEditing] = useState(false);
    const [formData, setFormData] = useState({});
    const [loading, setLoading] = useState(false);
    const [stats, setStats] = useState({ total: 0, completed: 0, pending: 0 });
    const { user } = useAuth();

    useEffect(() => {
        loadProfile();
        loadStats();
    }, []);

    const loadProfile = async () => {
        try {
            const response = await window.apiClient.getMe();
            setProfile(response);
            setFormData({
                name: response.first_name || '',
                bio: response.bio || '',
                location: response.location || '',
                profile_image: response.profile_image || '',
                availability: response.availability || [],
                is_public: response.is_public
            });
        } catch (error) {
            console.error('Failed to load profile:', error);
        }
    };

    const loadStats = async () => {
        try {
            const response = await window.apiClient.getRequests();
            const reqs = response.requests || [];
            setStats({
                total: reqs.length,
                completed: reqs.filter(r => r.status === 'completed').length,
                pending: reqs.filter(r => r.status === 'pending').length
            });
        } catch (error) {
            console.error('Failed to load stats:', error);
        }
    };

    const updateProfile = async () => {
        setLoading(true);
        try {
            await window.apiClient.updateProfile(formData);
            setEditing(false);
            loadProfile();
        } catch (error) {
            alert('Failed to update profile: ' + error.message);
        } finally {
            setLoading(false);
        }
    };

    const addSkill = async (type, skill) => {
        try {
            if (type === 'offered') {
                await window.apiClient.addSkillOffered(skill);
            } else {
                await window.apiClient.addSkillWanted(skill);
            }
            loadProfile();
        } catch (error) {
            alert('Failed to add skill: ' + error.message);
        }
    };

    const removeSkill = async (type, skill) => {
        try {
            if (type === 'offered') {
                await window.apiClient.removeSkillOffered(skill);
            } else {
                await window.apiClient.removeSkillWanted(skill);
            }
            loadProfile();
        } catch (error) {
            alert('Failed to remove skill: ' + error.message);
        }
    };

    if (!profile) return <Loading />;

    // Calculate profile completeness
    let completeness = 0;
    if (profile.first_name) completeness += 20;
    if (profile.bio) completeness += 20;
    if (profile.location) completeness += 20;
    if (profile.profile_image) completeness += 20;
    if (profile.skills_offered?.length > 0 || profile.skills_wanted?.length > 0) completeness += 20;

    return (
        <div className="container mx-auto px-4 py-8 text-slate-100 max-w-5xl">
            {completeness < 100 && (
                <div className="bg-brand-600/20 border border-brand-500/30 rounded-2xl p-4 mb-6 animate-fadeIn">
                    <div className="flex justify-between items-center mb-2">
                        <span className="font-semibold text-brand-300">Complete your profile to get 3x more matches!</span>
                        <span className="text-sm text-brand-400 font-bold">{completeness}% Complete</span>
                    </div>
                    <div className="h-2 bg-slate-800 rounded-full overflow-hidden">
                        <div className="h-full bg-gradient-to-r from-brand-500 to-brand-400 animate-progressFill" style={{ width: `${completeness}%` }}></div>
                    </div>
                </div>
            )}
            <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
                
                {/* Left Column: Profile Info & Stats */}
                <div className="md:col-span-1 space-y-6">
                    <div className="bg-slate-800/60 border border-slate-700 rounded-2xl shadow-md p-6 text-center">
                        <div className="relative inline-block mb-4">
                            {profile.profile_image ? (
                                <img src={profile.profile_image} alt={profile.first_name} className="w-24 h-24 rounded-full object-cover border-4 border-brand-500" />
                            ) : (
                                <div className="w-24 h-24 bg-gradient-to-br from-brand-500 to-brand-700 rounded-full flex items-center justify-center text-white font-bold text-3xl border-4 border-brand-500 shadow-lg shadow-brand-500/30">
                                    {profile.first_name ? profile.first_name[0].toUpperCase() : 'U'}
                                </div>
                            )}
                        </div>
                        <h2 className="text-2xl font-bold text-white mb-1">{profile.first_name || 'Unknown'}</h2>
                        <p className="text-slate-400 mb-4">{profile.email}</p>
                        
                        {profile.location && (
                            <p className="text-slate-300 text-sm flex items-center justify-center gap-1 mb-4">
                                <svg className="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fillRule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clipRule="evenodd"></path></svg>
                                {profile.location}
                            </p>
                        )}
                        
                        <div className="flex items-center justify-center space-x-1 text-yellow-400 mb-6">
                            <span>⭐</span>
                            <span className="font-semibold">{profile.rating ? profile.rating.toFixed(1) : 'New'}</span>
                            <span className="text-slate-500 text-sm">({profile.rating_count || 0} reviews)</span>
                        </div>
                        
                        <button
                            onClick={() => setEditing(!editing)}
                            className="w-full bg-brand-600 text-white px-4 py-2.5 rounded-xl hover:bg-brand-500 transition-all duration-300 shadow-md shadow-brand-500/20 font-medium hover:shadow-lg hover:shadow-brand-500/30 btn-ripple"
                        >
                            {editing ? 'Cancel Editing' : 'Edit Profile'}
                        </button>
                    </div>

                    <div className="bg-slate-800/60 border border-slate-700 rounded-2xl shadow-md p-6">
                        <h3 className="font-bold text-white mb-4">Swap Statistics</h3>
                        <div className="space-y-4">
                            <div className="flex justify-between items-center p-3 bg-slate-900/50 rounded-xl border border-slate-700/50">
                                <span className="text-slate-400">Total Swaps</span>
                                <span className="font-semibold text-white">{stats.total}</span>
                            </div>
                            <div className="flex justify-between items-center p-3 bg-slate-900/50 rounded-xl border border-slate-700/50">
                                <span className="text-slate-400">Completed</span>
                                <span className="font-semibold text-green-400">{stats.completed}</span>
                            </div>
                            <div className="flex justify-between items-center p-3 bg-slate-900/50 rounded-xl border border-slate-700/50">
                                <span className="text-slate-400">Pending</span>
                                <span className="font-semibold text-yellow-400">{stats.pending}</span>
                            </div>
                        </div>
                    </div>
                </div>

                {/* Right Column: Bio, Skills, Availability */}
                <div className="md:col-span-2 space-y-6">
                    {editing ? (
                        <div className="bg-slate-800/60 border border-slate-700 rounded-2xl shadow-md p-6 space-y-4 animate-in fade-in">
                            <h3 className="font-bold text-xl text-white mb-4">Edit Profile</h3>
                            <div>
                                <label className="block text-sm font-medium text-slate-300 mb-1">Full Name</label>
                                <input
                                    type="text"
                                    className="w-full px-4 py-3 rounded-xl bg-slate-900/70 border border-slate-700 text-slate-100 focus:outline-none focus:ring-2 focus:ring-brand-600"
                                    value={formData.name}
                                    onChange={(e) => setFormData({...formData, name: e.target.value})}
                                />
                            </div>
                            <div>
                                <label className="block text-sm font-medium text-slate-300 mb-1">Bio</label>
                                <textarea
                                    className="w-full px-4 py-3 rounded-xl bg-slate-900/70 border border-slate-700 text-slate-100 focus:outline-none focus:ring-2 focus:ring-brand-600"
                                    rows="4"
                                    value={formData.bio}
                                    onChange={(e) => setFormData({...formData, bio: e.target.value})}
                                />
                            </div>
                            <div>
                                <label className="block text-sm font-medium text-slate-300 mb-1">Location</label>
                                <input
                                    type="text"
                                    className="w-full px-4 py-3 rounded-xl bg-slate-900/70 border border-slate-700 text-slate-100 focus:outline-none focus:ring-2 focus:ring-brand-600"
                                    value={formData.location}
                                    onChange={(e) => setFormData({...formData, location: e.target.value})}
                                />
                            </div>
                            <div>
                                <label className="block text-sm font-medium text-slate-300 mb-1">Profile Image URL</label>
                                <input
                                    type="url"
                                    className="w-full px-4 py-3 rounded-xl bg-slate-900/70 border border-slate-700 text-slate-100 focus:outline-none focus:ring-2 focus:ring-brand-600"
                                    value={formData.profile_image}
                                    onChange={(e) => setFormData({...formData, profile_image: e.target.value})}
                                />
                            </div>
                            <div className="flex items-center pt-2 pb-4">
                                <input
                                    type="checkbox"
                                    id="is_public"
                                    className="w-4 h-4 text-brand-600 bg-slate-900 border-slate-700 rounded focus:ring-brand-500 focus:ring-2"
                                    checked={formData.is_public}
                                    onChange={(e) => setFormData({...formData, is_public: e.target.checked})}
                                />
                                <label htmlFor="is_public" className="ml-2 text-sm font-medium text-slate-300">Public Profile</label>
                            </div>
                            <div className="flex justify-end pt-4 border-t border-slate-700/50">
                                <button
                                    onClick={updateProfile}
                                    disabled={loading}
                                    className="bg-brand-600 text-white px-6 py-2.5 rounded-xl hover:bg-brand-500 disabled:opacity-50 font-medium shadow-md shadow-brand-500/20"
                                >
                                    {loading ? 'Saving...' : 'Save Changes'}
                                </button>
                            </div>
                        </div>
                    ) : (
                        <>
                            <div className="bg-slate-800/60 border border-slate-700 rounded-2xl shadow-md p-6">
                                <h3 className="font-bold text-xl text-white mb-4">About Me</h3>
                                {profile.bio ? (
                                    <p className="text-slate-300 leading-relaxed">{profile.bio}</p>
                                ) : (
                                    <p className="text-slate-500 italic">No bio provided yet.</p>
                                )}
                            </div>

                            <div className="bg-slate-800/60 border border-slate-700 rounded-2xl shadow-md p-6">
                                <div className="flex justify-between items-center mb-4">
                                    <h3 className="font-bold text-xl text-white">Skills Offered</h3>
                                    <button
                                        onClick={() => {
                                            const skill = prompt('Enter skill you can offer:');
                                            if (skill) addSkill('offered', skill);
                                        }}
                                        className="text-brand-400 hover:text-brand-300 text-sm font-medium px-3 py-1.5 rounded-lg bg-brand-500/10 hover:bg-brand-500/20 transition-colors"
                                    >
                                        + Add Skill
                                    </button>
                                </div>
                                <div className="flex flex-wrap gap-2">
                                    {profile.skills_offered && profile.skills_offered.length > 0 ? (
                                        profile.skills_offered.map((skill, index) => (
                                            <span key={index} className="bg-green-500/10 border border-green-500/20 text-green-400 px-3 py-1.5 rounded-full text-sm font-medium flex items-center">
                                                {skill}
                                                <button
                                                    onClick={() => removeSkill('offered', skill)}
                                                    className="ml-2 text-green-500 hover:text-green-300 w-4 h-4 flex items-center justify-center rounded-full hover:bg-green-500/20 transition-colors"
                                                >
                                                    ×
                                                </button>
                                            </span>
                                        ))
                                    ) : (
                                        <p className="text-slate-500 text-sm italic w-full">You haven't added any skills to offer yet.</p>
                                    )}
                                </div>
                            </div>

                            <div className="bg-slate-800/60 border border-slate-700 rounded-2xl shadow-md p-6">
                                <div className="flex justify-between items-center mb-4">
                                    <h3 className="font-bold text-xl text-white">Skills Wanted</h3>
                                    <button
                                        onClick={() => {
                                            const skill = prompt('Enter skill you want to learn:');
                                            if (skill) addSkill('wanted', skill);
                                        }}
                                        className="text-brand-400 hover:text-brand-300 text-sm font-medium px-3 py-1.5 rounded-lg bg-brand-500/10 hover:bg-brand-500/20 transition-colors"
                                    >
                                        + Add Skill
                                    </button>
                                </div>
                                <div className="flex flex-wrap gap-2">
                                    {profile.skills_wanted && profile.skills_wanted.length > 0 ? (
                                        profile.skills_wanted.map((skill, index) => (
                                            <span key={index} className="bg-brand-500/10 border border-brand-500/20 text-brand-400 px-3 py-1.5 rounded-full text-sm font-medium flex items-center">
                                                {skill}
                                                <button
                                                    onClick={() => removeSkill('wanted', skill)}
                                                    className="ml-2 text-brand-500 hover:text-brand-300 w-4 h-4 flex items-center justify-center rounded-full hover:bg-brand-500/20 transition-colors"
                                                >
                                                    ×
                                                </button>
                                            </span>
                                        ))
                                    ) : (
                                        <p className="text-slate-500 text-sm italic w-full">You haven't added any skills you want to learn yet.</p>
                                    )}
                                </div>
                            </div>

                            <div className="bg-slate-800/60 border border-slate-700 rounded-2xl shadow-md p-6">
                                <h3 className="font-bold text-xl text-white mb-4">My Reviews</h3>
                                {profile.reviews && profile.reviews.length > 0 ? (
                                    <div className="space-y-4">
                                        {profile.reviews.map(rev => (
                                            <div key={rev.id} className="bg-slate-900/50 p-4 rounded-xl border border-slate-700/50">
                                                <div className="flex justify-between items-center mb-2">
                                                    <span className="font-semibold text-slate-200">{rev.reviewer_name}</span>
                                                    <span className="text-yellow-400">{"⭐".repeat(rev.rating)}</span>
                                                </div>
                                                <p className="text-slate-400 text-sm">{rev.text}</p>
                                                <div className="text-[10px] text-slate-500 mt-2">{new Date(rev.created_at).toLocaleDateString()}</div>
                                            </div>
                                        ))}
                                    </div>
                                ) : (
                                    <EmptyState icon="⭐" title="No Reviews Yet" description="Complete swaps to get reviews from your partners." />
                                )}
                            </div>
                        </>
                    )}
                </div>
            </div>
        </div>
    );
};

// Main App Component
const App = () => {
    const [currentView, setCurrentView] = useState('landing');
    const [isAuthModalOpen, setIsAuthModalOpen] = useState(false);
    const [authTab, setAuthTab] = useState('login');
    const { user, loading } = useAuth();

    useEffect(() => {
        const handleHashChange = () => {
            const fullHash = window.location.hash.slice(1) || '';
            // Extract route part (before query params)
            const hash = fullHash.split('?')[0];
            
            // Handle auth modal opening logic
            if (!user && (hash === 'login' || hash === 'signup')) {
              setAuthTab(hash);
              setIsAuthModalOpen(true);
              return;
            }

            // If no hash or invalid hash for logged in users, default to appropriate page
            if (!hash || hash === 'login' || hash === 'signup') {
                if (user) {
                    const newHash = user.role === 'admin' ? 'admin-overview' : 'home';
                    setCurrentView(newHash);
                    if (window.location.hash !== `#${newHash}`) {
                        window.history.replaceState(null, '', `#${newHash}`);
                    }
                } else {
                    setCurrentView('landing');
                    if (window.location.hash !== '') {
                        window.history.replaceState(null, '', window.location.pathname);
                    }
                }
                return;
            }
            
            setCurrentView(hash);
        };

        window.addEventListener('hashchange', handleHashChange);
        handleHashChange();

        return () => window.removeEventListener('hashchange', handleHashChange);
    }, [user]);

    const openAuthModal = (tab) => {
        setAuthTab(tab);
        setIsAuthModalOpen(true);
    };

    const closeAuthModal = () => {
        setIsAuthModalOpen(false);
    };

    if (loading) return <Loading />;

    const renderView = () => {
      if (!user) {
        return <LandingPage openAuthModal={openAuthModal} />;
      }
      if (user.role === 'admin') {
        switch (currentView) {
          case 'admin-stats':
            return <AdminStats />;
          case 'admin-users':
            return <AdminUsers />;
          case 'admin-overview':
          default:
            return <AdminOverview />;
        }
      }
      switch (currentView) {
        case 'home':
          return <HomePage />;
        case 'messages':
          return <MessagesPage />;
        case 'notifications':
          return <NotificationsPage />;
        case 'settings':
          return <SettingsPage />;
        case 'requests':
          return <RequestsPage />;
        case 'profile':
          return <ProfilePage />;
        case 'discover':
        default:
          return <DiscoverPage />;
      }
    };

    return (
        <div className="min-h-screen bg-slate-950 text-slate-100">
            <Navigation />
            {renderView()}
            <AuthModal 
                isOpen={isAuthModalOpen} 
                onClose={closeAuthModal} 
                initialTab={authTab} 
            />
        </div>
    );
};

// Initialize the app
const root = ReactDOM.createRoot(document.getElementById('root'));
root.render(
    <React.StrictMode>
        <AuthProvider>
            <App />
        </AuthProvider>
    </React.StrictMode>
);
